{# ═══ Announcement Bar ═══ #}
{% set ann_bg = theme.settings.get('announce_bg', '#0D0D0D') %}
{% set ann_color = theme.settings.get('announce_color', '#DDB87E') %}
{% set ann_dot = theme.settings.get('announce_dot_color', '#C6975B') %}
{% set ann_text_1 = theme.settings.get('announce_text_1', 'Free shipping on orders over SAR 500') %}
{% set ann_text_2 = theme.settings.get('announce_text_2', 'Lifetime warranty on all pieces') %}
{% set ann_text_3 = theme.settings.get('announce_text_3', 'Use code JEWEL25 for 25% off') %}
{% set ann_text_4 = theme.settings.get('announce_text_4', 'Handcrafted with love') %}

<div class="jw-announce" style="background:{{ ann_bg }}; color:{{ ann_color }};">
  <div class="jw-announce-track">
    {% for i in 1..2 %}
    <span class="jw-announce-item">{{ ann_text_1 }}</span>
    <span class="jw-announce-dot" style="background:{{ ann_dot }};"></span>
    <span class="jw-announce-item">{{ ann_text_2 }}</span>
    <span class="jw-announce-dot" style="background:{{ ann_dot }};"></span>
    <span class="jw-announce-item">{{ ann_text_3 }}</span>
    <span class="jw-announce-dot" style="background:{{ ann_dot }};"></span>
    <span class="jw-announce-item">{{ ann_text_4 }}</span>
    <span class="jw-announce-dot" style="background:{{ ann_dot }};"></span>
    {% endfor %}
  </div>
</div>

{# ═══ Header ═══ #}
<header class="jw-header">
  <div class="jw-header-inner">
    <nav class="jw-nav">
      <salla-menu source="header" display="default"></salla-menu>
    </nav>

    <a href="{{ store.url }}" class="jw-logo">
      {% if store.logo %}
        <img src="{{ store.logo }}" alt="{{ store.name }}" style="height:{{ theme.settings.get('logo_height', '36') }}px;">
      {% else %}
        {{ store.name }}
      {% endif %}
    </a>

    <nav class="jw-nav jw-nav-right">
      {# Search #}
      <button class="jw-icon-btn" onclick="salla.event.dispatch('search::open')">
        <i class="sicon-search"></i>
      </button>

      {# Wishlist #}
      <a href="{{ link('/wishlist') }}" class="jw-icon-btn">
        <i class="sicon-heart"></i>
      </a>

      {# User #}
      {% if user.type == 'user' %}
        <salla-user-menu></salla-user-menu>
      {% else %}
        <button class="jw-icon-btn" onclick="salla.event.dispatch('login::open')">
          <i class="sicon-user"></i>
        </button>
      {% endif %}

      {# Cart #}
      <salla-cart-summary widget-only>
        <button slot="widget" class="jw-icon-btn" id="jw-cart-btn">
          <i class="sicon-shopping-bag"></i>
        </button>
      </salla-cart-summary>

      {# Mobile menu #}
      <button class="jw-icon-btn jw-menu-toggle" onclick="salla.event.dispatch('menu::open')">
        <i class="sicon-menu"></i>
      </button>
    </nav>
  </div>
</header>
