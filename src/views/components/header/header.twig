{# ═══ Announcement Bar — Modular ═══ #}
{% set ann_show      = theme.settings.get('announce_show', true) %}
{% set ann_bg        = theme.settings.get('announce_bg', '#0D0D0D') %}
{% set ann_color     = theme.settings.get('announce_color', '#DDB87E') %}
{% set ann_dot       = theme.settings.get('announce_dot_color', '#C6975B') %}
{% set ann_mode      = theme.settings.get('announce_use_slider', false) %}
{% set ann_text_1    = theme.settings.get('announce_text_1', 'Free shipping on orders over SAR 500') %}
{% set ann_text_2    = theme.settings.get('announce_text_2', 'Lifetime warranty on all pieces') %}
{% set ann_text_3    = theme.settings.get('announce_text_3', 'Use code JEWEL25 for 25% off') %}
{% set ann_text_4    = theme.settings.get('announce_text_4', 'Handcrafted with love') %}
{% set ann_link      = theme.settings.get('announce_link', '') %}
{% set show_social   = theme.settings.get('announce_show_social', false) %}
{% set show_locale   = theme.settings.get('announce_show_locale', false) %}
{% set show_countdown = theme.settings.get('announce_show_countdown', false) %}
{% set show_cta      = theme.settings.get('announce_show_cta', false) %}
{% set ann_btn_label = theme.settings.get('announce_btn_label', 'SHOP NOW') %}
{% set ann_btn_link  = theme.settings.get('announce_btn_link', '') %}
{% set ann_btn_color = theme.settings.get('announce_btn_color', '#DDB87E') %}
{% set show_close    = theme.settings.get('announce_show_close', true) %}
{% set cd_year       = theme.settings.get('announce_cd_year', 2026) %}
{% set cd_month      = theme.settings.get('announce_cd_month', 12) %}
{% set cd_day        = theme.settings.get('announce_cd_day', 31) %}
{% set cd_hour       = theme.settings.get('announce_cd_hour', 0) %}
{% set cd_minute     = theme.settings.get('announce_cd_minute', 0) %}
{% set ann_texts = [ann_text_1, ann_text_2, ann_text_3, ann_text_4]|filter(t => t) %}

{% if ann_show and ann_texts|length %}
<div class="jw-announce" id="jw-announce"
     style="background:{{ ann_bg }};color:{{ ann_color }};"
     data-cd-target="{{ cd_year }}-{{ '%02d'|format(cd_month) }}-{{ '%02d'|format(cd_day) }}T{{ '%02d'|format(cd_hour) }}:{{ '%02d'|format(cd_minute) }}:00">

  {# Close button #}
  {% if show_close %}
  <button class="jw-announce-close" id="jw-announce-close" aria-label="{{ trans('common.elements.close') }}">
    <svg width="9" height="9" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l8 8M9 1l-8 8"/></svg>
  </button>
  {% endif %}

  {# LEFT — Social icons #}
  {% if show_social %}
  <div class="jw-announce-social">
    {% if store.social.twitter %}
      <a href="{{ store.social.twitter }}" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
    {% endif %}
    {% if store.social.instagram %}
      <a href="{{ store.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
    {% endif %}
    {% if store.social.snapchat %}
      <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener" aria-label="Snapchat"><svg viewBox="0 0 24 24"><path d="M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.299 4.847l-.003.06c-.012.18-.022.345-.03.51.075.045.203.09.401.09.3-.016.659-.12.959-.289a.85.85 0 01.944.362c.053.174.07.36.024.544-.087.36-.383.614-.672.822-.09.064-.18.12-.26.166l-.043.026c-.12.073-.219.132-.278.18-.12.09-.16.17-.158.24.015.2.166.39.36.54l.02.017c.12.09.25.18.35.27.39.3.68.66.8 1.11.06.2.07.41.04.6-.09.53-.47.93-1.13 1.19l-.14.05c-.12.04-.27.09-.41.12-.27.06-.56.11-.86.15-.11.02-.22.03-.33.05-.19.03-.31.06-.39.12-.1.07-.18.21-.24.39-.08.19-.17.39-.32.56-.3.36-.73.57-1.28.63-.46.05-.91.03-1.3-.01-.16-.02-.29-.03-.4-.04-.35-.02-.7.13-1.21.43-.5.3-1.05.64-1.84.89-.09.03-.18.04-.27.06-.1.01-.21.03-.31.03-.12 0-.24-.02-.36-.04-.89-.24-1.43-.58-1.93-.88-.52-.31-.87-.45-1.22-.44-.11.01-.24.02-.4.04-.39.04-.84.06-1.3.01-.55-.06-.98-.27-1.28-.63-.15-.17-.24-.37-.32-.56-.06-.18-.14-.32-.24-.39-.08-.06-.2-.09-.39-.12-.11-.02-.22-.03-.33-.05-.3-.04-.59-.09-.86-.15-.14-.03-.28-.08-.41-.12l-.14-.05c-.66-.26-1.04-.66-1.13-1.19-.03-.19-.02-.4.04-.6.12-.45.41-.81.8-1.11.1-.09.22-.18.35-.27l.02-.017c.2-.15.35-.34.36-.54 0-.07-.04-.15-.16-.24-.06-.05-.16-.11-.28-.18l-.04-.026c-.08-.046-.17-.102-.26-.166-.29-.21-.59-.46-.67-.82-.05-.18-.03-.37.02-.55a.85.85 0 01.35-.51.78.78 0 01.43-.14c.18 0 .35.05.51.15.3.17.66.31.96.29.2 0 .33-.04.4-.09a23.5 23.5 0 01-.03-.51l-.003-.06c-.104-1.628-.23-3.654.299-4.847C7.859 1.07 11.216.793 12.206.793z"/></svg></a>
    {% endif %}
    {% if store.social.facebook %}
      <a href="{{ store.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
    {% endif %}
    {% if store.social.youtube %}
      <a href="{{ store.social.youtube }}" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
    {% endif %}
  </div>
  {% endif %}

  {# CENTER — Marquee or Slider #}
  <div class="jw-announce-center">
    {% if not ann_mode %}
      {# Marquee mode #}
      <div class="jw-announce-track">
        {% for i in 1..2 %}
          {% for text in ann_texts %}
            {% if ann_link %}<a href="{{ ann_link }}" class="jw-announce-item">{{ text }}</a>{% else %}<span class="jw-announce-item">{{ text }}</span>{% endif %}
            <span class="jw-announce-dot" style="background:{{ ann_dot }};"></span>
          {% endfor %}
        {% endfor %}
      </div>
    {% else %}
      {# Slider mode #}
      <button class="jw-announce-arrow" id="jw-ann-prev" aria-label="{{ trans('blocks.header.announce_prev') }}">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L5 8l5 5"/></svg>
      </button>
      <div class="jw-announce-slider" id="jw-ann-slider">
        <div class="jw-announce-slides">
          {% for text in ann_texts %}
          <div class="jw-announce-slide">
            {% if ann_link %}<a href="{{ ann_link }}" class="jw-announce-item">{{ text }}</a>{% else %}<span class="jw-announce-item">{{ text }}</span>{% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      <button class="jw-announce-arrow" id="jw-ann-next" aria-label="{{ trans('blocks.header.announce_next') }}">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3l5 5-5 5"/></svg>
      </button>
    {% endif %}

    {# Inline CTA button #}
    {% if show_cta and ann_btn_label %}
    <a href="{{ ann_btn_link ?: ann_link ?: '#' }}" class="jw-announce-btn" style="border-color:{{ ann_btn_color }}33;color:{{ ann_btn_color }}">
      <span>{{ ann_btn_label }}</span>
    </a>
    {% endif %}
  </div>

  {# RIGHT — Countdown + Locale #}
  <div class="jw-announce-right">
    {% if show_countdown %}
    <div class="jw-announce-countdown" id="jw-countdown">
      <span class="jw-cd-num" data-cd="d">00</span><span class="jw-cd-sep">:</span>
      <span class="jw-cd-num" data-cd="h">00</span><span class="jw-cd-sep">:</span>
      <span class="jw-cd-num" data-cd="m">00</span><span class="jw-cd-sep">:</span>
      <span class="jw-cd-num" data-cd="s">00</span>
    </div>
    {% endif %}

    {% if show_locale and (store.settings.is_multilingual or store.settings.currencies_enabled) %}
    <div class="jw-announce-locale">
      <button class="jw-announce-locale-btn" onclick="salla.event.dispatch('localization::open')">
        {{ user.language.name }} / {{ currency.symbol }}
        <svg width="8" height="8" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 4.5l3 3 3-3"/></svg>
      </button>
    </div>
    {% endif %}
  </div>

</div>
{% endif %}

{# ═══ Header — Glow layout: nav left · logo center · actions right ═══ #}
<header class="jw-header" id="jw-header">
  <div class="jw-header-inner">
    <div class="jw-header__left">
      <a href="#mobile-menu" class="jw-icon-btn jw-menu-toggle" aria-label="{{ trans('blocks.header.main_menu') }}">
        <i class="sicon-menu"></i>
      </a>
      <div class="jw-header__nav-wrap">
        <custom-main-menu></custom-main-menu>
      </div>
    </div>

    <a href="{{ store.url }}" class="jw-logo">
      {% if store.logo %}
        <img src="{{ store.logo }}" alt="{{ store.name }}" style="height:{{ theme.settings.get('logo_height', '36') }}px;">
      {% else %}
        <span class="jw-logo-text">{{ store.name }}</span>
      {% endif %}
    </a>
    {% if is_page('index') %}
    <h1 class="sr-only">{{ store.name }}</h1>
    {% endif %}

    <nav class="jw-nav jw-nav-right" aria-label="{{ trans('blocks.header.main_menu') }}">
      <button type="button" class="jw-icon-btn" onclick="salla.event.dispatch('search::open')" aria-label="{{ trans('blocks.header.search') }}">
        <i class="sicon-search"></i>
      </button>

      <a href="{{ link('/wishlist') }}" class="jw-icon-btn" aria-label="{{ trans('blocks.header.wishlist') }}">
        <i class="sicon-heart"></i>
      </a>

      {% if user.type == 'user' %}
        <salla-user-menu avatar-only show-header></salla-user-menu>
      {% else %}
        <button type="button" class="jw-icon-btn" onclick="salla.event.dispatch('login::open')" aria-label="{{ trans('blocks.header.account') }}">
          <i class="sicon-user"></i>
        </button>
      {% endif %}

      <salla-cart-summary widget-only>
        <button slot="widget" type="button" class="jw-icon-btn" id="jw-cart-btn" aria-label="{{ trans('blocks.header.cart') }}">
          <i class="sicon-shopping-bag"></i>
        </button>
      </salla-cart-summary>
    </nav>
  </div>
</header>
