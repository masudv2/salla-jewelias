{#
  Banner Bottom Component

  Variables (component.*):
    show_banner_bottom  (boolean) - Toggle section visibility
    space_on            (number)  - Margin top in px
    space_below         (number)  - Margin bottom in px
    banner_bottom_img   (string)  - Banner image URL
    banner_bottom_link  (string)  - Banner link URL
    banner_bottom_title (string)  - Banner title / alt text

  position - Component sort index
#}
{% if component.show_banner_bottom %}
<section class="one-block-image" id="section-{{ position }}">
  <div class="container">
    <div class="block-image">
       <a href="{{ component.banner_bottom_link }}" title="{{ component.banner_bottom_title }}">
          {% if component.banner_bottom_img %}
          <img src="{{ component.banner_bottom_img }}" alt="{{ component.banner_bottom_title | e }}"
               class="lazyload">
          {% else %}
          <span class="not_img">930 x 100px</span>
          {% endif %}
        </a>
    </div>
  </div>
</section>
{% endif %}

<style>
  #section-{{ position }}{
    margin-top: {{ component.space_on }}px;
    margin-bottom: {{ component.space_below }}px;
  }
</style>
