{#
  Banner Top Component

  Variables (component.*):
    show_banner_top       (boolean) - Toggle section visibility
    space_move_up         (string)  - Negative margin-top value (e.g. "-245")
    space_on              (number)  - Padding top in px
    space_below           (number)  - Padding bottom in px
    show_content_banner_top (boolean) - Show text content below banners
    content_banner_top    (string)  - Banner content paragraph text

  Blocks (component.blocks[]):
    ct_img                       (string)  - Image URL
    ct_link                      (string)  - Link URL
    ct_heading                   (string)  - Heading text
    ct_sub_heading               (string)  - Sub heading text
    ct_desc                      (string)  - Description text
    show_banner_image_content    (boolean) - Show overlay content
    banner_image_content_position (string) - Position: top|middle|bottom
    font_size_sub_heading        (string)  - Sub heading font size
    color_sub_heading            (string)  - Sub heading color
    color_border_sub_heading     (string)  - Sub heading border color
    font_size_heading            (string)  - Heading font size
    color_heading                (string)  - Heading color
    font_size_desc               (string)  - Description font size
    color_desc                   (string)  - Description color

  position - Component sort index
#}
{% if component.show_banner_top %}
<section class="home-top-banner" id="section-{{ position }}">
  <div class="container">
    <div class="row-bt">
      {% for block in component.blocks %}
        <div class="banner-image column col column-{{ loop.index }} {% if not component.show_content_banner_top %}no-banner-content{% endif %}">
          <div class="col-12 custom-item">
            <a href="{{ block.ct_link }}" title="{{ block.ct_heading }}">
              {% if block.ct_img %}
              <img src="{{ block.ct_img }}" alt="{{ block.ct_heading }}"
                   class="lazyload">
              {% else %}
              <span class="not_img">370 x 435px</span>
              {% endif %}
            </a>
            {% if block.show_banner_image_content %}
              <div class="caption {% if block.banner_image_content_position == 'top' %} position-top{% elseif block.banner_image_content_position == 'bottom' %} position-bottom {% else %} position-middle{% endif %}">
                {% if block.ct_sub_heading %}
                <h5 class="sub-heading" style="font-size: {{ block.font_size_sub_heading }};color: {{ block.color_sub_heading }}; border-bottom: 1px solid {{ block.color_border_sub_heading }};">
                  {{ block.ct_sub_heading }}
                </h5>
                {% endif %}

                {% if block.ct_heading %}
                <h3 class="heading" style="font-size: {{ block.font_size_heading }};color: {{ block.color_heading }}">
                  {{ block.ct_heading }}
                </h3>
                {% endif %}

                {% if block.ct_desc %}
                <p class="desc-text" style="font-size: {{ block.font_size_desc }};color: {{ block.color_desc }}">
                  {{ block.ct_desc }}
                </p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    {% if component.show_content_banner_top %}
        <div class="banner-content">
            <p>{{ component.content_banner_top }}</p>
        </div>
    {% endif %}
  </div>
</section>
{% endif %}

<style>
  #section-{{ position }}{
    margin-top: {{ component.space_move_up }}px;
    padding-top: {{ component.space_on }}px;
    padding-bottom: {{ component.space_below }}px;
  }
</style>
