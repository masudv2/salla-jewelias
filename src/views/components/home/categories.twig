{% set tag = component.tag|default('Explore') %}
{% set heading = component.heading|default('Shop by Category') %}
{% set view_all_link = component.view_all_link|default('/categories') %}
{% set cats = component.cats %}

<section class="jw-section jw-rv">
  <div class="jw-section-head">
    <div>
      <div class="jw-section-tag">{{ tag }}</div>
      <h2 class="jw-section-h2">{{ heading }}</h2>
    </div>
    <a href="{{ view_all_link }}" class="jw-view-all">
      {{ trans('common.elements.view_all') }}
      <i class="sicon-keyboard_arrow_left rtl:hidden"></i>
      <i class="sicon-keyboard_arrow_right ltr:hidden"></i>
    </a>
  </div>

  <div class="jw-cats-grid">
    {% if cats|length %}
      {% for cat in cats %}
      <a href="{{ cat.link|default('#') }}" class="jw-cat-card jw-rv jw-rv-d{{ loop.index }}">
        <img src="{{ cat.image|default('https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=600&q=80') }}" alt="{{ cat.name|default('Category') }}">
        <div class="jw-cat-info">
          <div class="jw-cat-name">{{ cat.name|default('Category') }}</div>
          <div class="jw-cat-count">{{ cat.count|default('') }}</div>
        </div>
      </a>
      {% endfor %}
    {% else %}
      <a href="#" class="jw-cat-card jw-rv jw-rv-d1">
        <img src="https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=600&q=80" alt="Rings">
        <div class="jw-cat-info"><div class="jw-cat-name">Rings</div><div class="jw-cat-count">42 pieces</div></div>
      </a>
      <a href="#" class="jw-cat-card jw-rv jw-rv-d2">
        <img src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=600&q=80" alt="Necklaces">
        <div class="jw-cat-info"><div class="jw-cat-name">Necklaces</div><div class="jw-cat-count">38 pieces</div></div>
      </a>
      <a href="#" class="jw-cat-card jw-rv jw-rv-d3">
        <img src="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=600&q=80" alt="Earrings">
        <div class="jw-cat-info"><div class="jw-cat-name">Earrings</div><div class="jw-cat-count">56 pieces</div></div>
      </a>
      <a href="#" class="jw-cat-card jw-rv jw-rv-d4">
        <img src="https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=600&q=80" alt="Bracelets">
        <div class="jw-cat-info"><div class="jw-cat-name">Bracelets</div><div class="jw-cat-count">29 pieces</div></div>
      </a>
    {% endif %}
  </div>
</section>
