{# Collection Banner — Noor Theme (wide landscape cards) #}
{% set show   = component.show|default(true) %}
{% set label  = component.label|default('') %}
{% set title  = component.title|default('') %}
{% set items  = component.items|default([]) %}

{% if not items|length %}
  {% set items = [
    { image: 'https://images.unsplash.com/photo-1617038220319-276d3cfab638?w=800&q=80', title: 'Wedding Collection', url: '/products' },
    { image: 'https://images.unsplash.com/photo-1602751584552-8ba73aad10e1?w=800&q=80', title: 'Everyday Elegance', url: '/products' },
    { image: 'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=800&q=80', title: 'Gift Guide', url: '/products' }
  ] %}
{% endif %}

{% if show and items|length %}
<section class="nr-section">
  {% if label or title %}
  <div class="nr-section__header">
    {% if label %}<span class="nr-section-label">{{ label }}</span>{% endif %}
    {% if title %}<h2 class="nr-section__title">{{ title }}</h2>{% endif %}
  </div>
  {% endif %}

  <div class="nr-collection-banner-grid">
    {% for item in items %}
    <a href="{{ item.url|default('#') }}" class="nr-collection-banner-card nr-reveal--up">
      <div class="nr-collection-banner-card__media">
        <img src="{{ item.image }}" alt="{{ item.title|default('') }}" loading="lazy">
      </div>
      <div class="nr-collection-banner-card__info">
        <h3 class="nr-collection-banner-card__title">{{ item.title }}</h3>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
