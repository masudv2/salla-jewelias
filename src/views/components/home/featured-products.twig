{% set tag = component.tag|default('Just Arrived') %}
{% set heading = component.heading|default('New Collection') %}
{% set view_all_link = component.view_all_link|default('/products') %}
{% set source = component.source|default('latest') %}

<section class="jw-section jw-rv" style="padding-top:0">
  <div class="jw-section-head">
    <div>
      <div class="jw-section-tag">{{ tag }}</div>
      <h2 class="jw-section-h2">{{ heading }}</h2>
    </div>
    <a href="{{ view_all_link }}" class="jw-view-all">
      {{ trans('common.elements.view_all') }}
      <i class="sicon-keyboard_arrow_left rtl:hidden"></i>
      <i class="sicon-keyboard_arrow_right ltr:hidden"></i>
    </a>
  </div>

  <div class="jw-products">
    {% for product in products %}
      <a href="{{ product.url }}" class="jw-p-card jw-rv jw-rv-d{{ loop.index }}">
        <div class="jw-p-img">
          <img src="{{ product.image.url }}" alt="{{ product.name }}" loading="lazy">
          {% if product.is_on_sale %}
            <span class="jw-p-label sale">{{ product.discount_ends }}</span>
          {% elseif loop.index <= 2 %}
            <span class="jw-p-label">{{ trans('common.elements.new') }}</span>
          {% endif %}
          <div class="jw-p-actions">
            <salla-add-product-button product-id="{{ product.id }}" class="jw-p-add">
              {{ trans('pages.products.add_to_cart') }}
            </salla-add-product-button>
            <salla-favorite-button product-id="{{ product.id }}" class="jw-p-wish">
              <i class="sicon-heart"></i>
            </salla-favorite-button>
          </div>
        </div>
        {% if product.brand %}
          <div class="jw-p-brand">{{ product.brand.name }}</div>
        {% endif %}
        <div class="jw-p-name">{{ product.name }}</div>
        <div class="jw-p-price">
          {{ product.price|money }}
          {% if product.is_on_sale %}
            <span class="was">{{ product.regular_price|money }}</span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</section>
