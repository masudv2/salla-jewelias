{# Featured Products Grid — Noor Theme #}
{% set show          = component.show|default(true) %}
{% set label         = component.label|default('') %}
{% set title         = component.title|default('') %}
{% set show_view_all = component.show_view_all|default(true) %}
{% set view_all_link = component.view_all_link|default('/products') %}
{% set columns       = component.columns|default(4) %}
{% set show_rating   = component.show_rating|default(true) %}
{% set show_quick_add = component.show_quick_add|default(true) %}
{% set show_wishlist = component.show_wishlist|default(true) %}
{% set products_count = component.products_count|default(4) %}

{% if show %}
<section class="nr-section">
  <div class="nr-container">
    <div class="nr-section-header nr-reveal">
      <div>
        {% if label %}<span class="nr-section-label">{{ label }}</span>{% endif %}
        {% if title %}<h2>{{ title }}</h2>{% endif %}
      </div>
      {% if show_view_all %}
        <a href="{{ view_all_link }}" class="nr-btn-text">{{ trans('common.elements.show_all') }} <span class="nr-btn__arrow">&rarr;</span></a>
      {% endif %}
    </div>
    <div class="nr-product-grid" style="grid-template-columns:repeat({{ columns }},1fr)">
      <salla-products-list source="latest" limit="{{ products_count }}">
        <div slot="product-card" class="nr-card nr-reveal">
          <div class="nr-card__media">
            <a href="{product_url}">
              <img class="nr-card__img nr-card__img--primary" src="{product_image}" alt="{product_name}" loading="lazy">
            </a>
            {% if show_wishlist %}
            <div class="nr-card__actions">
              <salla-button shape="icon" color="light" aria-label="Wishlist" onclick="salla.wishlist.toggle({product_id})">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </salla-button>
            </div>
            {% endif %}
            {% if show_quick_add %}
            <div class="nr-card__quick-add">
              <salla-add-product-button product-id="{product_id}" class="nr-btn-solid" style="width:100%;padding:0.65rem;font-size:0.75rem;letter-spacing:0.06em;text-transform:uppercase">
                {{ trans('pages.products.add_to_cart') }}
              </salla-add-product-button>
            </div>
            {% endif %}
          </div>
          <div class="nr-card__info">
            <a href="{product_url}"><h4 class="nr-card__title">{product_name}</h4></a>
            <div class="nr-card__price">{product_price}</div>
            {% if show_rating %}
            <div class="nr-card__rating">
              <salla-rating-stars value="{product_rating}"></salla-rating-stars>
            </div>
            {% endif %}
          </div>
        </div>
      </salla-products-list>
    </div>
  </div>
</section>
{% endif %}
