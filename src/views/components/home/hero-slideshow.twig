{# Hero Slideshow — Noor Theme #}
{% set show        = component.show|default(true) %}
{% set slides      = component.slides|default([]) %}
{% if not slides|length %}
  {% set slides = [
    { image: 'https://cdn.salla.sa/KVlQp/TJbMRBsDCxSqy4Zzq3HqJAbyyPNgOVoMNODHRXCw.jpg', title: 'Timeless Elegance', subtitle: 'New Collection 2026', btn_text: 'Shop Now', btn_link: '/products', content_position: 'left' },
    { image: 'https://cdn.salla.sa/KVlQp/QXbW8dnCCKbkMoiqRQlfuWKUJiOBh1ERHgRFiVVj.jpg', title: 'Crafted with Passion', subtitle: 'Handmade Luxury Pieces', btn_text: 'Explore', btn_link: '/products', content_position: 'center' }
  ] %}
{% endif %}
{% set autoplay    = component.autoplay|default(true) %}
{% set speed       = component.speed|default(6000) %}
{% set nav_style   = component.nav_style|default('both') %}
{% set height      = component.height|default('full') %}
{% set overlay_color   = component.overlay_color|default('#000000') %}
{% set overlay_opacity = component.overlay_opacity|default(40) %}
{% set ken_burns   = component.ken_burns|default(true) %}

{% if show and slides|length %}
{% set height_class = height == 'full' ? 'min-height:90vh' : (height == 'large' ? 'min-height:70vh' : 'min-height:50vh') %}

<section class="nr-hero{% if ken_burns %} nr-hero--ken-burns{% endif %}"
         data-nr-hero
         data-nr-autoplay="{{ speed }}"
         style="{{ height_class }}">

  {% for slide in slides %}
  <div class="nr-hero__slide{% if loop.first %} is-active{% endif %}" data-nr-slide>
    {% if slide.image %}
      <img class="nr-hero__img" src="{{ slide.image }}" alt="{{ slide.title|default('') }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}">
    {% endif %}

    <div class="nr-hero__overlay" style="background:linear-gradient(to right, {{ overlay_color }}{{ '%02x'|format((overlay_opacity / 100 * 255)|round) }} 0%, {{ overlay_color }}33 50%, transparent 100%)"></div>

    <div class="nr-hero__content" style="{% if slide.content_position == 'center' %}text-align:center;align-items:center;max-width:800px;margin:0 auto{% elseif slide.content_position == 'right' %}align-items:flex-end;text-align:right;margin-inline-start:auto{% endif %}">
      {% if slide.subtitle %}
        <p class="nr-hero__subtitle">{{ slide.subtitle }}</p>
      {% endif %}

      {% if slide.title %}
        <h1 class="nr-hero__title">{{ slide.title }}</h1>
      {% endif %}

      <div class="nr-hero__actions">
        {% if slide.btn_text %}
          <a href="{{ slide.btn_link|default('#') }}" class="nr-btn-solid"{% if slide.btn_color %} style="background:{{ slide.btn_color }}"{% endif %}>
            {{ slide.btn_text }} <span class="nr-btn__arrow">&rarr;</span>
          </a>
        {% endif %}
        {% if slide.btn2_text %}
          <a href="{{ slide.btn2_link|default('#') }}" class="nr-btn-outline" style="border-color:rgba(255,255,255,0.4);color:#fff">
            {{ slide.btn2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
  {% endfor %}

  {# Dots #}
  {% if nav_style == 'dots' or nav_style == 'both' %}
  <div class="nr-hero__dots">
    {% for slide in slides %}
      <button class="nr-hero__dot{% if loop.first %} is-active{% endif %}" data-nr-dot aria-label="Slide {{ loop.index }}"></button>
    {% endfor %}
  </div>
  {% endif %}

  {# Arrows #}
  {% if nav_style == 'arrows' or nav_style == 'both' %}
  <div class="nr-hero__arrows">
    <button class="nr-hero__arrow" data-nr-prev aria-label="{{ trans('common.elements.previous') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="nr-hero__arrow" data-nr-next aria-label="{{ trans('common.elements.next') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
  {% endif %}
</section>
{% endif %}
