{% set tag_text = component.tag_text|default('Summer 2026') %}
{% set title = component.title|default('Where Art Meets <em>Elegance</em>') %}
{% set description = component.description|default('Discover handcrafted jewelry designed for those who appreciate the extraordinary.') %}
{% set btn_text = component.btn_text|default('Shop Collection') %}
{% set btn_link = component.btn_link|default('#') %}
{% set btn_bg = component.btn_bg|default('#0D0D0D') %}
{% set btn2_text = component.btn2_text|default('Our Story') %}
{% set btn2_link = component.btn2_link|default('#') %}
{% set show_btn2 = component.show_btn2|default(true) %}
{% set hero_image = component.hero_image|default('') %}
{% set hero_bg_color = component.hero_bg_color|default('#E8D5C4') %}
{% set float_title = component.float_title|default('Certified Authentic') %}
{% set float_desc = component.float_desc|default('Every piece comes with certificate') %}
{% set show_float = component.show_float|default(true) %}

<section class="jw-hero" id="hero-{{ position }}">
  <div class="jw-hero-text">
    {% if tag_text %}
    <div class="jw-hero-tag">
      <span class="jw-hero-tag-dot"></span>
      {{ tag_text }}
    </div>
    {% endif %}

    <h1 class="jw-hero-title">{{ title|raw }}</h1>

    {% if description %}
    <p class="jw-hero-desc">{{ description }}</p>
    {% endif %}

    <div class="jw-hero-actions">
      {% if btn_text %}
      <a href="{{ btn_link }}" class="jw-btn-primary" style="background:{{ btn_bg }};">
        {{ btn_text }}
        <i class="sicon-keyboard_arrow_left rtl:hidden"></i>
        <i class="sicon-keyboard_arrow_right ltr:hidden"></i>
      </a>
      {% endif %}

      {% if show_btn2 and btn2_text %}
      <a href="{{ btn2_link }}" class="jw-btn-ghost">
        {{ btn2_text }}
      </a>
      {% endif %}
    </div>
  </div>

  <div class="jw-hero-image" style="background:{{ hero_bg_color }};">
    {% if hero_image %}
      <img src="{{ hero_image }}" alt="{{ tag_text }}">
    {% else %}
      <img src="https://images.unsplash.com/photo-1515562141589-67f0d569b538?w=1200&q=85" alt="Jewelias">
    {% endif %}

    {% if show_float %}
    <div class="jw-hero-float">
      <div class="jw-float-icon">
        <i class="sicon-shield-check"></i>
      </div>
      <div>
        <div class="jw-float-text">{{ float_title }}</div>
        <div class="jw-float-sub">{{ float_desc }}</div>
      </div>
    </div>
    {% endif %}
  </div>
</section>
