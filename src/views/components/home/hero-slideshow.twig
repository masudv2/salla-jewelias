{# Hero Slideshow — Noor Theme #}
{% set show        = component.show|default(true) %}
{% set slides      = component.slides|default([]) %}
{% if not slides|length %}
  {% set slides = [
    { image: 'https://images.unsplash.com/photo-1617038220319-276d3cfab638?w=1920&q=80', title: 'Timeless Elegance', subtitle: 'New Collection 2026', description: 'Discover handcrafted pieces that tell your story', btn_text: 'Shop Now', btn_link: '/products', content_position: 'left' },
    { image: 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=1920&q=80', title: 'Crafted with Passion', subtitle: 'Handmade Luxury Pieces', description: 'Each piece is a work of art, made with love and precision', btn_text: 'Explore', btn_link: '/products', content_position: 'center' },
    { image: 'https://images.unsplash.com/photo-1515562141589-67f0d4e2f1b6?w=1920&q=80', title: 'The Art of Adornment', subtitle: 'Limited Edition', description: 'Exclusive designs available for a limited time only', btn_text: 'View Collection', btn_link: '/products', btn2_text: 'Learn More', btn2_link: '/about', content_position: 'left' }
  ] %}
{% endif %}
{% set autoplay    = component.autoplay|default(true) %}
{% set speed       = component.speed|default(6000) %}
{% set height_raw  = component.height|default('full') %}
{% set height      = height_raw is iterable ? (height_raw[0].value|default('full')) : height_raw %}
{% set overlay_color   = component.overlay_color|default('#000000') %}
{% set overlay_opacity = component.overlay_opacity|default(50) %}
{% set ken_burns   = component.ken_burns|default(true) %}
{% set btn_style_raw = component.btn_style|default('outline-light') %}
{% set btn_style   = btn_style_raw is iterable ? (btn_style_raw[0].value|default('outline-light')) : btn_style_raw %}
{% set btn_pos_raw = component.btn_position|default('left') %}
{% set btn_pos     = btn_pos_raw is iterable ? (btn_pos_raw[0].value|default('left')) : btn_pos_raw %}
{% set show_progress = component.show_progress|default(true) %}

{% if show and slides|length %}
{% set height_class = height == 'full' ? 'min-height:100vh;min-height:100dvh' : (height == 'large' ? 'min-height:75vh' : 'min-height:55vh') %}

<section class="nr-hero{% if ken_burns %} nr-hero--ken-burns{% endif %}"
         data-nr-hero
         data-slide-speed="{{ speed }}"
         style="{{ height_class }}">

  <div class="nr-hero__slides" id="nr-hero-slides">
    {% for slide in slides %}
    {% set pos_raw = slide.content_position|default(slide['slides.content_position']|default('left')) %}
    {% set pos = pos_raw is iterable ? (pos_raw[0].value|default('left')) : pos_raw %}
    <div class="nr-hero__slide{% if loop.first %} is-active{% endif %}">

      {% set img = slide.image|default(slide['slides.image']|default('')) %}
      {% if img %}
        <img class="nr-hero__img" src="{{ img }}" alt="{{ slide.title|default(slide['slides.title']|default('')) }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}">
      {% endif %}

      <div class="nr-hero__overlay" style="background:linear-gradient(180deg, {{ overlay_color }}{{ '%02x'|format((overlay_opacity / 100 * 0.15 * 255)|round) }} 0%, transparent 40%), linear-gradient(90deg, {{ overlay_color }}{{ '%02x'|format((overlay_opacity / 100 * 255)|round) }} 0%, {{ overlay_color }}{{ '%02x'|format((overlay_opacity / 100 * 0.3 * 255)|round) }} 55%, transparent 100%)"></div>

      {% set title = slide.title|default(slide['slides.title']|default('')) %}
      {% set subtitle = slide.subtitle|default(slide['slides.subtitle']|default('')) %}
      {% set desc = slide.description|default(slide['slides.description']|default('')) %}
      {% set btn1 = slide.btn_text|default(slide['slides.btn_text']|default('')) %}
      {% set btn1_link = slide.btn_link|default(slide['slides.btn_link']|default('#')) %}
      {% set btn1_color = slide.btn_color|default(slide['slides.btn_color']|default('')) %}
      {% set btn2 = slide.btn2_text|default(slide['slides.btn2_text']|default('')) %}
      {% set btn2_link = slide.btn2_link|default(slide['slides.btn2_link']|default('#')) %}

      <div class="nr-hero__content nr-hero__content--{{ pos }}">
        {% if subtitle %}
          <span class="nr-hero__label">{{ subtitle }}</span>
        {% endif %}

        {% if title %}
          <h2 class="nr-hero__title">{{ title|raw }}</h2>
        {% endif %}

        {% if desc %}
          <p class="nr-hero__desc">{{ desc }}</p>
        {% endif %}

        {% if btn1 or btn2 %}
        <div class="nr-hero__actions nr-hero__actions--{{ btn_pos }}">
          {% if btn1 %}
            {% if btn_style == 'solid' %}
              <a href="{{ btn1_link }}" class="nr-btn-solid"{% if btn1_color %} style="background:{{ btn1_color }}"{% endif %}>
                {{ btn1 }} <span class="nr-btn__arrow">&rarr;</span>
              </a>
            {% else %}
              <a href="{{ btn1_link }}" class="nr-btn-outline--light">
                {{ btn1 }} <span class="nr-btn__arrow">&rarr;</span>
              </a>
            {% endif %}
          {% endif %}
          {% if btn2 %}
            <a href="{{ btn2_link }}" class="nr-btn-outline--light">
              {{ btn2 }}
            </a>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

  {# Bottom bar: counter | progress | arrows #}
  {% if slides|length > 1 %}
  <div class="nr-hero__bottom">
    <div class="nr-hero__counter">
      <span class="nr-hero__counter-current">01</span>
      <span class="nr-hero__counter-sep">/</span>
      <span class="nr-hero__counter-total">{{ '%02d'|format(slides|length) }}</span>
    </div>

    {% if show_progress %}
    <div class="nr-hero__progress">
      <div class="nr-hero__progress-bar" id="nr-hero-progress"></div>
    </div>
    {% endif %}

    <div class="nr-hero__nav">
      <button class="nr-hero__nav-btn" id="nr-hero-prev" aria-label="{{ trans('common.elements.previous') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="nr-hero__nav-btn" id="nr-hero-next" aria-label="{{ trans('common.elements.next') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
  {% endif %}

</section>
{% endif %}
