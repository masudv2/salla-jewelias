{# Image Promos (3-up) — Noor Theme #}
{% set show      = component.show|default(true) %}
{% set label     = component.label|default('Curated For You') %}
{% set title     = component.title|default('Shop by Style') %}
{% set promos    = component.promos|default([]) %}
{% if not promos|length %}
  {% set promos = [
    { image: 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=800&q=80', title: 'Rings', link_text: 'Shop Now', link: '/products' },
    { image: 'https://images.unsplash.com/photo-1515562141589-67f0d4e2f1b6?w=800&q=80', title: 'Necklaces', link_text: 'Shop Now', link: '/products' },
    { image: 'https://images.unsplash.com/photo-1602751584552-8ba73aad10e1?w=800&q=80', title: 'Bracelets', link_text: 'Shop Now', link: '/products' }
  ] %}
{% endif %}
{% set columns   = component.columns|default(3) %}
{% set overlay_raw   = component.overlay_style|default('gradient') %}
{% set overlay_style = overlay_raw is iterable ? (overlay_raw[0].value|default('gradient')) : overlay_raw %}

{% if show and promos|length %}
<section class="nr-section">
  <div class="nr-container">
    {% if title %}
    <div class="nr-section-header nr-reveal" style="justify-content:center;text-align:center">
      <div>
        {% if label %}<span class="nr-section-label" style="justify-content:center">{{ label }}</span>{% endif %}
        <h2>{{ title }}</h2>
      </div>
    </div>
    {% endif %}
    <div class="nr-promos nr-reveal" style="grid-template-columns:repeat({{ columns }},1fr)">
      {% for promo in promos %}
      <a href="{{ promo.link|default('#') }}" class="nr-promo">
        {% if promo.image %}
          <img src="{{ promo.image }}" alt="{{ promo.title|default('') }}" loading="lazy">
        {% endif %}
        <div class="nr-promo__overlay"{% if overlay_style == 'none' %} style="background:none"{% endif %}>
          {% if promo.title %}
            <h3 class="nr-promo__title">{{ promo.title }}</h3>
          {% endif %}
          {% if promo.link_text %}
            <span class="nr-promo__link">{{ promo.link_text }} &rarr;</span>
          {% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
