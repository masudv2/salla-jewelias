{# Instagram Grid — Noor Theme #}
{% set show         = component.show|default(true) %}
{% set label        = component.label|default('') %}
{% set title        = component.title|default('') %}
{% set handle       = component.handle|default('@noor.jewelry') %}
{% set images       = component.images|default([]) %}
{% set columns      = component.columns|default(6) %}
{% set show_overlay = component.show_overlay|default(true) %}

{% if show and images|length %}
<section class="nr-section" style="padding-bottom:0">
  {% if title %}
  <div class="nr-container" style="margin-bottom:var(--nr-space-lg)">
    <div class="nr-section-header nr-reveal" style="justify-content:center;text-align:center">
      <div>
        {% if label %}<span class="nr-section-label" style="justify-content:center">{{ label }}</span>{% endif %}
        <h2>{{ title }}</h2>
      </div>
    </div>
  </div>
  {% endif %}
  <div class="nr-instagram nr-reveal" style="grid-template-columns:repeat({{ columns }},1fr)">
    {% for img in images %}
    <a href="{{ img.link|default('#') }}" class="nr-instagram__item" target="_blank" rel="noopener">
      {% if img.image %}
        <img src="{{ img.image }}" alt="{{ handle }} post {{ loop.index }}" loading="lazy">
      {% endif %}
      {% if show_overlay %}
      <div class="nr-instagram__overlay">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </div>
      {% endif %}
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
