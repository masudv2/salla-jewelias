{#
| Variable                          | Type    | Description                                  |
|-----------------------------------|---------|----------------------------------------------|
| component.show_instagram          | bool    | Whether to show the Instagram section        |
| component.instagram_title         | string  | Section heading text                         |
| component.instagram_des           | string  | Description text below heading               |
| component.images_per_row          | string  | Number of images per row: "3", "4", or "5"   |
| component.display_instagram_button| bool    | Whether to show the CTA button               |
| component.instagram_button_text   | string  | Button label text                            |
| component.instagram_button_link   | string  | Button destination URL                       |
| component.blocks                  | array   | Collection of Instagram image items          |
| component.blocks[].enable         | bool    | Whether this image is active                 |
| component.blocks[].image          | string  | Image URL                                    |
| component.blocks[].link           | string  | Link URL for the image                       |
| position                          | string  | Unique section identifier                    |
#}
{% if component.show_instagram %}

<section class="home-instagram" id="home-instagram-{{ position }}">
  <div class="container medium">
    {% if component.instagram_title %}
    <div class="widget-title">
      <h3 class="box-title">
        <i class="sicon-instagram" aria-hidden="true"></i>
        {{ component.instagram_title }}
      </h3>
      {% if component.instagram_des %}
      <p class="desc-text">
        {{ component.instagram_des }}
      </p>
      {% endif %}
    </div>
    {% endif %}

    {% set col_class = 'five-col' %}
    {% if component.images_per_row == '3' %}
      {% set col_class = 'three-col' %}
    {% elseif component.images_per_row == '4' %}
      {% set col_class = 'four-col' %}
    {% endif %}

    <div class="row {{ col_class }}" id="instafeed-{{ position }}">
      {% for block in component.blocks %}
      {% if block.enable and block.image %}
      <a class="item animate-hvr" href="{{ block.link|default('#') }}">
          <img src="{{ block.image }}" alt="{{ component.instagram_title | e }}" loading="lazy" />
      </a>
      {% endif %}
      {% endfor %}
    </div>

    {% if component.display_instagram_button and component.instagram_button_text %}
    <a href="{{ component.instagram_button_link }}" title="{{ component.instagram_button_text }}" class="btn">
      {{ component.instagram_button_text }}
    </a>
    {% endif %}
  </div>
</section>

<style>
  .home-instagram .row.three-col .item { width: calc(100% / 3); }
  .home-instagram .row.four-col .item  { width: calc(100% / 4); }
  .home-instagram .row.five-col .item  { width: calc(100% / 5); }
  .home-instagram .row { display: flex; flex-wrap: wrap; }
  .home-instagram .item img { width: 100%; height: auto; display: block; }
  .home-instagram .item.animate-hvr { overflow: hidden; }
  .home-instagram .item.animate-hvr img { transition: transform 0.4s ease; }
  .home-instagram .item.animate-hvr:hover img { transform: scale(1.05); }
  @media (max-width: 767px) {
    .home-instagram .row .item { width: 50% !important; }
  }
</style>
{% endif %}
