{# Latest Products — rendered by Salla's built-in component #}
{% if products|length %}
<section style="max-width:1280px; margin:0 auto; padding:64px 48px;">
  <h2 style="font-family:var(--jw-font-serif); font-size:2rem; text-align:center; margin-bottom:40px;">
    {{ trans('blocks.home.latest_products') }}
  </h2>
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:24px;">
    {% for product in products %}
      {% include 'components.product.product-card' %}
    {% endfor %}
  </div>
</section>
{% endif %}
