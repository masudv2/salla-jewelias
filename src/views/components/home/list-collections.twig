{#
  List Collections Component

  Variables (from twilight.json):
  - component.coll_des (string): Section title text
  - component.list_collection_results_per_row (string): Items per row ("2"|"3"|"4"|"5")
  - component.style_categories (string): Display mode ("style_show_all"|"style_little")
  - component.collections (array): All available collections (used when style_show_all)
  - component.blocks (array): Selected collection blocks (used when style_little)
    - block.collection (object): Collection data for each block
  - position (number): Component sort index from twilight.json
#}
<header class="page-header">
  <h2>
    {{ component.coll_des }}
  </h2>
</header>

<div class="list-category">

  {# Loop through collections based on display mode #}

  <div class="row">
    {% if component.style_categories == 'style_show_all' %}
      {% for collection in component.collections %}
      {% if collection.handle != 'frontpage' and collection.products_count > 0 %}
          {% include 'pages.partials.collection.card' with { collection: collection } %}
      {% endif %}
      {% endfor %}

    {% else %}

    {% for block in component.blocks %}
      {% include 'pages.partials.collection.card' with { collection: block.collection } %}
    {% endfor %}
    {% endif %}
  </div>
</div>
