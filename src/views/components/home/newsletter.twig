{# Newsletter — Noor Theme #}
{% set show         = component.show|default(true) %}
{% set title        = component.title|default('Stay in the Know') %}
{% set description  = component.description|default('Subscribe to receive updates on new collections, exclusive offers, and styling inspiration.') %}
{% set btn_text     = component.btn_text|default('Subscribe') %}
{% set bg_style     = component.bg_style|default('warm') %}
{% set show_divider = component.show_divider|default(true) %}

{% set bg_class = bg_style == 'warm' ? 'nr-newsletter--warm' : (bg_style == 'dark' ? 'nr-newsletter--dark' : '') %}

{% if show %}
<section class="nr-newsletter {{ bg_class }} nr-reveal">
  <div class="nr-container">
    {% if show_divider %}
    <div class="nr-divider" style="margin-bottom:2.5rem">
      <span class="nr-divider__line"></span>
      <span class="nr-divider__diamond"></span>
      <span class="nr-divider__line"></span>
    </div>
    {% endif %}
    {% if title %}
      <h2 class="nr-newsletter__title">{{ title }}</h2>
    {% endif %}
    {% if description %}
      <p class="nr-newsletter__desc">{{ description }}</p>
    {% endif %}
    <salla-newsletter class="nr-newsletter__form">
      <input type="email" class="nr-newsletter__input" placeholder="{{ trans('common.elements.email') }}" slot="input">
      <button type="submit" class="nr-newsletter__btn" slot="submit">{{ btn_text }} <span class="nr-btn__arrow">&rarr;</span></button>
    </salla-newsletter>
  </div>
</section>
{% endif %}
