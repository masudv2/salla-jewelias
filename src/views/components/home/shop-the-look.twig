{# Shop the Look — Noor Theme #}
{% set show  = component.show|default(true) %}
{% set label = component.label|default('Shop the Look') %}
{% set title = component.title|default('Complete the Set') %}
{% set image = component.image|default('https://images.unsplash.com/photo-1617038220319-276d3cfab638?w=1200&q=80') %}
{% set pins  = component.pins|default([]) %}

{% if not pins|length %}
  {% set pins = [
    { x: 25, y: 35, product_name: 'Diamond Pendant', product_price: '1,200 SAR', product_image: 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=200&q=80', product_url: '/products' },
    { x: 55, y: 60, product_name: 'Gold Ring', product_price: '850 SAR', product_image: 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=200&q=80', product_url: '/products' },
    { x: 75, y: 30, product_name: 'Pearl Earrings', product_price: '680 SAR', product_image: 'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=200&q=80', product_url: '/products' }
  ] %}
{% endif %}

{% if show %}
<section class="nr-section">
  {% if label or title %}
  <div class="nr-section__header">
    {% if label %}<span class="nr-section-label">{{ label }}</span>{% endif %}
    {% if title %}<h2 class="nr-section__title">{{ title }}</h2>{% endif %}
  </div>
  {% endif %}

  <div class="nr-shop-look nr-reveal--up" data-nr-shop-look>
    <img src="{{ image }}" alt="{{ title }}" class="nr-shop-look__img" loading="lazy">

    {% for pin in pins %}
    <button class="nr-shop-look__pin" style="left:{{ pin.x }}%;top:{{ pin.y }}%" data-nr-pin="{{ loop.index0 }}" aria-label="{{ pin.product_name }}">
      <span class="nr-shop-look__pin-dot"></span>
      <span class="nr-shop-look__pin-ring"></span>
    </button>

    <div class="nr-shop-look__popup" data-nr-popup="{{ loop.index0 }}">
      <a href="{{ pin.product_url|default('#') }}" class="nr-shop-look__popup-inner">
        {% if pin.product_image %}
        <img src="{{ pin.product_image }}" alt="{{ pin.product_name }}" class="nr-shop-look__popup-img">
        {% endif %}
        <div class="nr-shop-look__popup-info">
          <span class="nr-shop-look__popup-name">{{ pin.product_name }}</span>
          <span class="nr-shop-look__popup-price">{{ pin.product_price }}</span>
        </div>
      </a>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}
