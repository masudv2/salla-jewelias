{# Split Collection Banner — Noor Theme #}
{% set show        = component.show|default(true) %}
{% set image       = component.image|default('https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=960&q=80') %}
{% set reverse     = component.reverse|default(false) %}
{% set label       = component.label|default('The Collection') %}
{% set title       = component.title|default('Pieces That Define You') %}
{% set description = component.description|default('Every jewel in our collection is handcrafted by master artisans, combining traditional techniques with contemporary design to create pieces that are as unique as you are.') %}
{% set btn_text    = component.btn_text|default('Discover More') %}
{% set btn_link    = component.btn_link|default('/products') %}
{% set bg_style    = component.bg_style|default('warm') %}

{% if show %}
<section class="nr-section">
  <div class="nr-split{% if reverse %} nr-split--reverse{% endif %}">
    <div class="nr-split__media nr-reveal--left">
      {% if image %}
        <img src="{{ image }}" alt="{{ title }}" loading="lazy">
      {% endif %}
    </div>
    <div class="nr-split__content nr-reveal--right{% if bg_style == 'warm' %} nr-split__content--warm{% endif %}">
      {% if label %}
        <span class="nr-section-label">{{ label }}</span>
      {% endif %}
      {% if title %}
        <h2 class="nr-split__title">{{ title }}</h2>
      {% endif %}
      {% if description %}
        <p class="nr-split__desc">{{ description }}</p>
      {% endif %}
      {% if btn_text %}
        <a href="{{ btn_link }}" class="nr-btn-solid">
          {{ btn_text }} <span class="nr-btn__arrow">&rarr;</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}
