{# Split Collection Banner — Noor Theme #}
{% set show           = component.show|default(true) %}
{% set image          = component.image|default('') %}
{% set image_position = component.image_position|default('left') %}
{% set label          = component.label|default('') %}
{% set title          = component.title|default('') %}
{% set description    = component.description|default('') %}
{% set btn_text       = component.btn_text|default('') %}
{% set btn_link       = component.btn_link|default('#') %}
{% set bg_color       = component.bg_color|default('#ffffff') %}
{% set text_align     = component.text_align|default('left') %}

{% if show %}
<section>
  <div class="nr-split{% if image_position == 'right' %}" style="direction:rtl{% endif %}">
    <div class="nr-split__media nr-reveal--left"{% if image_position == 'right' %} style="direction:ltr;order:2"{% endif %}>
      {% if image %}
        <img src="{{ image }}" alt="{{ title }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;min-height:550px">
      {% endif %}
    </div>
    <div class="nr-split__content nr-reveal--right" style="background:{{ bg_color }};{% if image_position == 'right' %}direction:ltr;order:1{% endif %};{% if text_align == 'center' %}align-items:center;text-align:center{% endif %}">
      {% if label %}
        <span class="nr-section-label">{{ label }}</span>
      {% endif %}
      {% if title %}
        <h2 class="nr-split__title">{{ title }}</h2>
      {% endif %}
      {% if description %}
        <p class="nr-split__desc">{{ description }}</p>
      {% endif %}
      {% if btn_text %}
        <a href="{{ btn_link }}" class="nr-btn-solid" style="align-self:{% if text_align == 'center' %}center{% else %}flex-start{% endif %}">
          {{ btn_text }} <span class="nr-btn__arrow">&rarr;</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}
