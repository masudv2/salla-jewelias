{# Store Features — Noor Theme #}
{#
| Variable      | Type   | Description                                                      |
|---------------|--------|------------------------------------------------------------------|
| items[]       | array  | List of features                                                 |
| items[].icon  | string | SallaIcons css class                                             |
| items[].title | string | Title of the feature                                             |
| items[].text  | string | Subtitle for the feature                                         |
| position      | Int    | Sorting number start from zero                                   |
#}
{% set feature_items = items|default([]) %}
{% if not feature_items|length %}
  {% set feature_items = [
    { icon: 'sicon-shipping-fast', title: 'Free Shipping', text: 'On orders over SAR 500' },
    { icon: 'sicon-shield-check', title: 'Lifetime Warranty', text: 'On every piece we craft' },
    { icon: 'sicon-gift', title: 'Gift Wrapping', text: 'Complimentary luxury packaging' },
    { icon: 'sicon-undo', title: 'Easy Returns', text: '30-day hassle-free returns' }
  ] %}
{% endif %}

<section class="nr-section nr-features nr-features--bordered">
  <div class="nr-container">
    <div class="nr-features__grid" style="grid-template-columns:repeat(4,1fr)">
      {% for item in feature_items %}
      <div class="nr-features__item nr-reveal--up">
        {% if item.icon %}
          <i class="{{ item.icon }} nr-features__icon"></i>
        {% endif %}
        {% if item.title %}
          <h4 class="nr-features__title">{{ item.title }}</h4>
        {% endif %}
        {% if item.text %}
          <p class="nr-features__text">{{ item.text }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
