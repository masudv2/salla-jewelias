{#
| Variable      | Type   | Description                                                      |
|---------------|--------|------------------------------------------------------------------|
| items[]       | array  | List of features                                                 |
| items[].icon  | string | SallaIcons css class                                             |
| items[].title | string | Title of the feature                                             |
| items[].text  | string | Subtitle for the feature                                         |
| position      | Int    | Sorting number start from zero                                   |
#}
<section class="nr-section" style="border-top:1px solid var(--nr-border);border-bottom:1px solid var(--nr-border)">
  <div class="nr-container">
    <div class="nr-trust-strip">
      {% for item in items %}
      <div class="nr-trust-item">
        {% if item.icon %}
          <i class="{{ item.icon }}" style="font-size:1.5rem;opacity:0.7"></i>
        {% endif %}
        <div>
          {% if item.title %}<strong>{{ item.title }}</strong>{% endif %}
          {% if item.text %}<p style="font-size:0.85rem;opacity:0.7;margin:0">{{ item.text }}</p>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
