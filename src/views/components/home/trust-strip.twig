{# Trust / Award Icon Strip — Noor Theme #}
{% set show       = component.show|default(true) %}
{% set items      = component.items|default([]) %}
{% if not items|length %}
  {% set items = [
    { label: 'Free Shipping' },
    { label: 'Secure Payment' },
    { label: 'Lifetime Warranty' },
    { label: '24/7 Support' },
    { label: 'Easy Returns' }
  ] %}
{% endif %}
{% set bg_color   = component.bg_color|default('#ffffff') %}
{% set show_separators = component.show_separators|default(true) %}

{% if show and items|length %}
<section style="border-top:1px solid var(--nr-border);border-bottom:1px solid var(--nr-border);background:{{ bg_color }}">
  <div class="nr-container">
    <div class="nr-trust-strip nr-reveal">
      {% for item in items %}
      <div class="nr-trust-item">
        {% if item.icon %}
          <img src="{{ item.icon }}" alt="{{ item.label }}" style="width:36px;height:36px;opacity:0.7">
        {% endif %}
        {% if item.label %}
          <span>{{ item.label }}</span>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
