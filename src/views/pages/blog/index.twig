{#
| Variable     | Type           | Description          |
|--------------|----------------|----------------------|
| slides       | ?Article[]     | Featured articles    |
| articles     | Article[]      | Blog articles list   |
| categories   | BlogCategory[] | Blog categories      |
#}
{% extends "layouts.master" %}

{% block content %}
<div class="nr-container" style="padding-bottom:var(--nr-space-2xl)">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <div class="nr-blog-layout">
    {# Sidebar categories #}
    <nav class="nr-blog-layout__sidebar" aria-label="Sidebar">
      <h2 class="nr-footer__heading">{{ trans('pages.blog_categories.categories') }}</h2>
      <ul class="nr-blog-layout__cat-list">
        {% for category in categories %}
          <li>
            <a class="nr-blog-layout__cat-link{{ category.is_current ? ' is-active' : '' }}" href="{{ category.url }}">
              {{ category.name }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="nr-blog-layout__main">
      {# Featured slider #}
      {% if slides|length %}
        <salla-slider id="blog-home-slider" type="blog" auto-play auto-height show-controls="false" pagination
          class="nr-blog-slider">
          <div slot="items">
            {% for article in slides %}
              <div class="swiper-slide nr-blog-slider__slide has-overlay {{ article.has_image ? '' : 'no-thumb' }}">
                <img class="nr-blog-slider__img" src="{{ article.image.url }}" alt="{{ article.image.alt }}">
                <div class="nr-blog-slider__content">
                  <div class="nr-blog-slider__meta">
                    <span><i class="sicon-calendar-date"></i> {{ article.created_at|date }}</span>
                    <a href="{{ article.author.url }}"><i class="sicon-user"></i> {{ article.author.name }}</a>
                  </div>
                  <h3 class="nr-blog-slider__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                  <p class="nr-blog-slider__excerpt">{{ article.summary }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </salla-slider>
      {% else %}
        <h1 class="nr-section__title" style="margin-bottom:var(--nr-space-lg)">{{ page.title }}</h1>
      {% endif %}

      {# Articles grid #}
      {% if articles|length %}
        {% hook 'blog:index.items.start' %}
        <salla-infinite-scroll class="nr-blog__grid" next-page="{{ articles.next_page }}" autoload>
          {% for article in articles %}
            <article class="nr-blog-card">
              <a href="{{ article.url }}" class="nr-blog-card__media">
                <img src="{{ article.image.url }}" alt="{{ article.image.alt }}" loading="lazy">
              </a>
              <div class="nr-blog-card__info">
                <span class="nr-blog-card__date">{{ article.created_at|date }}</span>
                <h3 class="nr-blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                <p class="nr-blog-card__excerpt">{{ article.summary }}</p>
                {% if store.settings.blog.allow_likes_and_comments %}
                  <div class="nr-blog-card__stats">
                    {% if article.likes_count %}<span><i class="sicon-thumbs-up"></i> {{ article.likes_count }}</span>{% endif %}
                    {% if article.comments_count %}<span><i class="sicon-chat"></i> {{ article.comments_count }}</span>{% endif %}
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </salla-infinite-scroll>
        {% hook 'blog:index.items.end' %}
      {% elseif not slides|length %}
        <div class="nr-empty-state">
          <i class="sicon-inbox nr-empty-state__icon"></i>
          <p class="nr-empty-state__text">{{ trans('pages.blog_categories.no_articles') }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
