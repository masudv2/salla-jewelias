{#
| Variable        | Type          | Description |
|-----------------|---------------|-------------|
| article         | Article       |             |
| article.title   | string        |             |
| article.body    | string *HTML  |             |
| related         | Article[]     |             |
#}
{% extends "layouts.master" %}
{% block content %}
<div class="nr-container" style="padding-bottom:var(--nr-space-2xl)">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <div class="nr-blog-single-layout">
    <main class="nr-blog-single">
      <h1 class="nr-blog-single__title">{{ article.title }}</h1>

      <div class="nr-blog-single__meta">
        <span><i class="sicon-calendar-date"></i> {{ article.created_at|date }}</span>
        <a href="{{ article.author.url }}"><i class="sicon-user"></i> {{ article.author.name }}</a>
      </div>

      {% if article.has_image %}
        <div class="nr-blog-single__hero">
          <img src="{{ article.image.url }}" alt="{{ article.image.alt }}">
        </div>
      {% endif %}

      {% if store.settings.blog.allow_likes_and_comments %}
        <div class="nr-blog-card__stats" style="margin-bottom:var(--nr-space-md)">
          <button id="blog-like" data-blog-id="{{ article.key }}" style="display:flex;align-items:center;gap:4px;background:none;border:none;cursor:pointer;color:var(--nr-primary)">
            <i class="sicon-thumbs-up"></i> <span>{{ article.likes_count }}</span>
          </button>
          {% if article.comments_count %}
            <span><i class="sicon-chat"></i> {{ article.comments_count }}</span>
          {% endif %}
        </div>
      {% endif %}

      <article class="nr-blog-single__content content-entry">
        {{ article.body|replace({'&nbsp;': ' '})|raw }}
      </article>

      {% if article.tags|length %}
        <div class="nr-pdp__tags" style="margin-top:var(--nr-space-lg);padding-top:var(--nr-space-md);border-top:1px solid var(--nr-border)">
          {% for tag in article.tags %}
            <a href="{{ tag.url }}" class="nr-pdp__tag"><i class="sicon-tag"></i> {{ tag.name }}</a>
          {% endfor %}
        </div>
      {% endif %}

      {% if store.settings.blog.allow_likes_and_comments %}
        <salla-comments item-id="{{ article.key }}" type="blog"></salla-comments>
      {% endif %}
    </main>

    <aside class="nr-blog-single-aside">
      {% if related|length %}
        <h2 class="nr-footer__heading">{{ trans('pages.blog_articles.related') }}</h2>
        {% hook 'blog:single.items.start' %}
        {% for article in related %}
          <a href="{{ article.url }}" class="nr-blog-related">
            <div class="nr-blog-related__img">
              {% if article.has_image %}
                <img src="{{ article.image.url }}" alt="{{ article.image.alt }}" loading="lazy">
              {% endif %}
            </div>
            <div class="nr-blog-related__info">
              <span class="nr-blog-card__date">{{ article.created_at|date }}</span>
              <h3 class="nr-blog-card__title">{{ article.title }}</h3>
            </div>
          </a>
        {% endfor %}
        {% hook 'blog:single.items.end' %}
      {% endif %}
    </aside>
  </div>
</div>
{% endblock %}
