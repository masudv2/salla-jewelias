{#
| Variable   | Type         | Description                                                |
|------------|--------------|------------------------------------------------------------|
| page       | object       |                                                            |
| page.title | string       |                                                            |
| page.slug  | string       |                                                            |
| brands     | Collection[] | Brands grouped by char, ex:{b:[{'name':'brand1',...},...]} |
#}
{% extends "layouts.master" %}
{% block content %}
<div class="nr-container" style="padding-bottom:var(--nr-space-2xl)">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <h1 class="nr-page-single__title" style="text-align:start;margin-bottom:var(--nr-space-lg)">{{ page.title }}</h1>

  {% if brands|length %}
    <div class="nr-brands-nav">
      <ul class="nr-brands-nav__list" id="brands-nav">
        <li></li>
        {% for char,brands_group in brands %}
          <li>
            <a class="nr-brands-nav__item" href="#brand-section-{{ loop.index }}" data-id="{{ loop.index }}">
              {{ char }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

    {% hook 'brands:index.items.start' %}

    {% for char,brandGroup in brands %}
      <section id="brand-section-{{ loop.index }}" class="nr-brands-section">
        <div class="nr-brands-section__char">
          <span data-id="{{ loop.index }}" class="nr-brands-section__letter">{{ char }}</span>
          <div class="nr-brands-section__line"></div>
        </div>
        <div class="nr-brands-section__grid">
          {% for brand in brandGroup %}
            <a href="{{ brand.url }}" class="nr-brands-section__item">
              <img src="{{ brand.logo }}" alt="{{ brand.name }}" loading="lazy">
            </a>
          {% endfor %}
        </div>
      </section>
    {% endfor %}

    {% hook 'brands:index.items.end' %}
  {% else %}
    <div class="nr-empty-state">
      <i class="sicon-award-ribbon nr-empty-state__icon"></i>
      <h2 class="nr-empty-state__title">{{ trans('pages.brands.non_brands') }}</h2>
      <p class="nr-empty-state__text">{{ trans('pages.brands.try_again') }}</p>
    </div>
  {% endif %}
</div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'pages.js' | asset }}"></script>
{% endblock %}
