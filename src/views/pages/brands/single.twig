{#
| Variable          | Type                 | Description                                               |
|-------------------|----------------------|-----------------------------------------------------------|
| page              | object               |                                                           |
| page.title        | string               |                                                           |
| page.slug         | string               |                                                           |
| brand             | Brand *              |                                                           |
| brand.id          | int                  |                                                           |
| brand.name        | string               |                                                           |
| brand.url         | string               |                                                           |
| brand.logo        | string               |                                                           |
| brand.banner      | ?string              | Null when is not set, or merchant doesn't want to show it |
| brand.description | string               |                                                           |
#}
{% extends "layouts.master" %}
{% block content %}
{% if brand.banner %}
  <div class="nr-brand-banner">
    <img src="{{ brand.banner }}" alt="{{ brand.name }}" loading="eager">
  </div>
{% endif %}

<div class="nr-container" style="padding-bottom:var(--nr-space-2xl)">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  {% hook 'brands:single.details.start' %}

  <header class="nr-brand-header">
    <img class="nr-brand-header__logo" src="{{ brand.logo }}" alt="{{ brand.name }}" loading="lazy">
    <div class="nr-brand-header__info">
      <h1 class="nr-brand-header__name">{{ brand.name }}</h1>
      <p class="nr-brand-header__desc">{{ brand.description|raw }}</p>
    </div>
  </header>

  {% hook 'brands:single.details.end' %}

  {% if products|length %}
    {% hook 'brands:single.items.start' %}
    <salla-products-list source="{{ page.slug }}" source-value="{{ page.id }}"></salla-products-list>
    {% hook 'brands:single.items.end' %}
  {% else %}
    <div class="nr-empty-state">
      <i class="sicon-award-ribbon nr-empty-state__icon"></i>
      <p class="nr-empty-state__text">{{ trans('pages.brands.non_products') }} {{ brand.name }}</p>
    </div>
  {% endif %}
</div>
{% endblock %}
