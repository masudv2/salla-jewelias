{#
| Variable       | Type       | Description                           |
|----------------|------------|---------------------------------------|
| cart           | Cart       | Full cart object                      |
| cart.items     | CartItem[] | Items in cart                         |
| cart.total     | float      | Cart total                            |
| cart.sub_total | float      | Subtotal before shipping/discounts    |
#}
{% extends "layouts.master" %}
{% block content %}
<div class="nr-container nr-cart">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <h1 class="nr-cart__title">{{ trans('blocks.header.cart') }}</h1>

  <salla-conditional-offer></salla-conditional-offer>

  <div class="nr-cart__layout">
    {# === Cart Items === #}
    <div class="nr-cart__items">
      {% hook 'cart:items.start' %}

      {% for item in cart.items %}
        <form onchange="salla.form.onChange('cart.updateItem', event)" id="item-{{ item.id }}">
          <div class="nr-cart-item">
            <input type="hidden" name="id" value="{{ item.id }}">

            <a href="{{ item.url }}" class="nr-cart-item__img-link">
              <img src="{{ item.product_image }}" alt="{{ item.product_name }}"
                   loading="{{ loop.first ? 'eager' : 'lazy' }}" class="nr-cart-item__img">
              <div class="free-ribbon {{ (item.price.getMoney().amount == 0 and item.has_discount) ? '' : 'hidden' }}">
                {{ trans('pages.loyalty_program.free_product') }}
              </div>
            </a>

            <div class="nr-cart-item__details">
              <a href="{{ item.url }}" class="nr-cart-item__name">{{ item.product_name }}</a>

              <span class="nr-cart-item__old-price item-regular-price {{ item.offer ? '' : 'hidden' }}">{{ item.product_price|money }}</span>
              <span class="nr-cart-item__old-price item-original-price {{ item.is_on_sale ? '' : 'hidden' }}" id="original_price">{{ item.original_price|money }}</span>
              <span class="nr-cart-item__price item-price {{ item.has_discount ? 'nr-cart-item__price--sale' : '' }}" id="has_discount">{{ item.price|money }}</span>

              {% if item.weight_label %}
                <p class="nr-cart-item__meta">{{ trans('pages.products.weight') }} {{ item.weight_label }}</p>
              {% endif %}

              <span class="old-offers {{ item.detailed_offers ? 'hidden' : '' }}">
                <i class="sicon-discount-calculator offer-icon {{ item.offer ? '' : 'hidden' }}"></i>
                <span class="offer-name {{ item.offer ? '' : 'hidden' }}">{{ item.offer.names }}</span>
              </span>

              <salla-cart-item-offers
                quantity="{{ item.quantity }}"
                item-id="{{ item.id }}"
                product-price="{{ item.product_price }}"
                offers="{{ item.detailed_offers|json_encode }}"></salla-cart-item-offers>
            </div>

            <div class="nr-cart-item__actions">
              {% if item.type == 'donating' %}
                <span></span>
              {% elseif item.is_hidden_quantity %}
                <input type="hidden" value="{{ item.quantity }}" name="quantity" aria-label="Quantity">
                <span>{{ item.quantity }}</span>
              {% else %}
                <salla-quantity-input cart-item-id="{{ item.id }}" max="{{ item.max_quantity }}"
                  value="{{ item.quantity }}" name="quantity" aria-label="Quantity"></salla-quantity-input>
              {% endif %}

              {% set item_total = item.detailed_offers|length > 0 ? item.total_special_price|money : item.total|money %}
              <p class="nr-cart-item__total">
                <span>{{ trans('pages.cart.total') }}:</span>
                <span class="item-total">{{ item.is_available ? item_total : trans('pages.cart.out_of_stock') }}</span>
              </p>
            </div>

            {% include 'pages.partials.product.options' with {product: item} %}

            <button type="button" class="nr-cart-item__remove btn--delete" aria-label="Remove"
                    onclick="salla.cart.deleteItem('{{ item.id }}').then(() => document.querySelector('#item-{{ item.id }}').remove())">
              <i class="sicon-cancel"></i>
            </button>
          </div>
        </form>
      {% else %}
        <div class="nr-empty-state">
          <i class="sicon-shopping-bag nr-empty-state__icon"></i>
          <h2 class="nr-empty-state__title">{{ trans('pages.cart.empty_cart') }}</h2>
          <a href="{{ link('/') }}" class="nr-btn-solid">{{ trans('common.elements.back_home') }}</a>
        </div>
      {% endfor %}

      {% if cart.options|length %}
        <div class="cart-options">
          {% for product_option in cart.options %}
            <form onchange="salla.form.onChange('cart.updateItem', event)" id="item-{{ product_option.id }}">
              <input type="hidden" name="id" value="{{ product_option.id }}">
              <input type="hidden" name="quantity" value="{{ product_option.quantity }}">
              {% include 'pages.partials.product.options' with { product: product_option } %}
            </form>
          {% endfor %}
        </div>
      {% endif %}

      <salla-offer></salla-offer>
      {% hook 'cart:items.end' %}
    </div>

    {# === Sidebar === #}
    {% hook 'cart:summary.start' %}

    {% if cart.items|length %}
    <div class="nr-cart__sidebar">
      {# Free shipping bar #}
      <div class="nr-cart__free-ship {{ cart.free_shipping_bar ? '' : 'hidden' }}" id="free-shipping">
        {% set is_free = cart.free_shipping_bar.has_free_shipping %}
        <i class="sicon-shipping-fast {{ theme.is_rtl ? 'flip-x' : '' }}"></i>
        <div>
          <h4 class="shipping-item">{{ trans('pages.cart.free_shipping') }}</h4>
          <p class="shipping-item" style="font-size:0.85rem;color:var(--nr-text-light)">
            <span id="free-shipping-msg">{{ (is_free ? trans('pages.cart.has_free_shipping') : trans('pages.cart.free_shipping_alert', {'amount': cart.free_shipping_bar.remaining|money}))|raw }}</span>
            <span class="emoji {{ is_free ? '' : 'hidden' }}" id="free-shipping-applied">🎉</span>
          </p>
        </div>
        <div class="{{ is_free ? 'hidden' : '' }}" id="free-shipping-bar" style="width:100%;height:6px;background:var(--nr-border);margin-top:0.75rem">
          <div class="progress-bg" style="height:100%;background:var(--nr-primary);width:{{ cart.free_shipping_bar.percent }}%;transition:width 500ms"></div>
        </div>
      </div>

      {% if loyalty and user.loyalty_points %}
        <div class="nr-cart__loyalty">
          <salla-loyalty customer-points='{{ user.loyalty_points }}'
            prize-points='{{ loyalty.prize.points }}'
            prize-title='{{ loyalty.prize.title }}'></salla-loyalty>
        </div>
      {% endif %}

      <div id="cart-gifting" class="{{ gift.enabled ? '' : 'hidden' }}" style="margin-bottom:var(--nr-space-md)">
        <salla-gifting id="salla-gifting" widget-title="{{ trans('pages.cart.gift_widget_title') }}" widget-subtitle="{{ gift.text }}" {{ gift.type }}-products vertical></salla-gifting>
      </div>

      <div class="nr-cart__summary">
        <h2 class="nr-cart__summary-title">{{ trans('pages.cart.summary') }}</h2>

        <div class="nr-cart__summary-row">
          <span>{{ trans(cart.tax_amount ? "pages.cart.items_total_without_tax" : "pages.cart.items_total") }}</span>
          <b id="sub-total">{{ cart.sub_total|money }}</b>
        </div>

        {% if cart.options|length %}
          <div class="nr-cart__summary-row">
            <span>{{ trans('pages.cart.order_options_total') }}</span>
            <b id="cart-options-total">{{ cart.options_total|money }}</b>
          </div>
        {% endif %}

        <div id="shipping-cost" class="nr-cart__summary-row {{ cart.has_shipping ? '' : 'hidden' }}">
          <span>{{ trans('pages.cart.shipping_cost') }}</span>
          <b>{{ cart.real_shipping_cost|money }}</b>
        </div>

        {% if store.settings.cart.apply_coupon_enabled %}
          <div style="padding:var(--nr-space-md) 0;border-bottom:1px solid var(--nr-border)">
            <salla-cart-coupons></salla-cart-coupons>
          </div>
        {% endif %}

        <div id="total-discount" class="nr-cart__summary-row {{ cart.total_discount ? '' : 'hidden' }}">
          <span>{{ trans('pages.cart.discount') }}</span>
          <b>- {{ cart.total_discount|money }}</b>
        </div>

        {% if cart.tax_amount %}
          <div class="nr-cart__summary-row">
            <span>{{ trans('pages.cart.VAT_tax_amount') }}</span>
            <b id="tax-amount">{{ cart.tax_amount|money }}</b>
          </div>
        {% endif %}

        <div class="nr-cart__summary-row nr-cart__summary-total">
          <span>{{ trans('pages.cart.final_total') }}</span>
          <b data-cart-total>{{ cart.total|money }}</b>
        </div>

        <div class="cart-submit-wrap" style="margin-top:var(--nr-space-lg)">
          {% hook 'cart:submit.start' %}
          <salla-button id="cart-submit" loader-position="center" width="wide">
            {{ trans('pages.cart.complete_order') }}
          </salla-button>
          {% hook 'cart:submit.end' %}
        </div>
        {% hook 'cart:summary.end' %}
      </div>

      <salla-tiered-offer></salla-tiered-offer>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'checkout.js'|asset }}"></script>
{% endblock %}
