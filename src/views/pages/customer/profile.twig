{#
| Variable                       | Type     | Description                                         |
|--------------------------------|----------|-----------------------------------------------------|
| page                           | object   |                                                     |
| page.title                     | string   |                                                     |
| page.slug                      | string   |                                                     |
#}
{% extends "layouts.customer" %}
{% block inner_content %}
  {% hook 'customer:profile.form.start' %}
  <form class="nr-profile-form" onsubmit="return salla.form.onSubmit('profile.update', event)">
    <div class="nr-profile-form__grid">

      {% hook 'customer:profile.form.fields.start' %}

      <div class="nr-profile-form__field">
        <label for="first-name" class="nr-form-label">{{ trans('pages.profile.first_name') }}</label>
        <input type="text" name="first_name" value="{{ user.first_name }}" id="first-name" required autocomplete="first_name" class="nr-form-input">
      </div>

      <div class="nr-profile-form__field">
        <label for="last-name" class="nr-form-label">{{ trans('pages.profile.last_name') }}</label>
        <input type="text" name="last_name" value="{{ user.last_name }}" id="last-name" autocomplete="last-name" required class="nr-form-input">
      </div>

      <div class="nr-profile-form__field">
        <label for="birthday" class="nr-form-label">{{ trans('pages.profile.birthday') }}</label>
        <salla-datetime-picker
          dateFormat="Y-m-d"
          value="{{ user.birthday }}"
          placeholder="{{ trans('pages.profile.birthday_placeholder') }}"
          required
          name="birthday"
        ></salla-datetime-picker>
      </div>

      <div class="nr-profile-form__field">
        <label for="gender" class="nr-form-label">{{ trans('pages.profile.gender') }}</label>
        <select class="nr-form-select" name="gender" required>
          <option placeholder value="">{{ trans('pages.profile.gender_placeholder') }}</option>
          <option value="male" {{ user.gender=='male'?'selected':'' }}>{{ trans('pages.profile.male') }}</option>
          <option value="female" {{ user.gender=='female'?'selected':'' }}>{{ trans('pages.profile.female') }}</option>
        </select>
      </div>

      <div class="nr-profile-form__field">
        <label for="email" class="nr-form-label">{{ trans('common.elements.email') }}</label>
        <input type="email" name="email" value="{{ user.email }}" id="email" class="nr-form-input" required>
      </div>

      <div class="nr-profile-form__field">
        <label for="international-mobile" class="nr-form-label">{{ trans('common.elements.mobile') }}</label>
        <salla-tel-input phone="{{ user.mobile }}"></salla-tel-input>
      </div>

      {% for field in custom_fields %}
        <div class="nr-profile-form__field">
          <label for="{{ field.id }}" class="nr-form-label">{{ field.label }}</label>
          {% if field.type == 'photo' %}
            <salla-file-upload
              instant-upload
              value="{{ field.value }}"
              url="{{ store.url|trim('/'~user.language_code) }}/upload-image"
              name="custom_fields[{{ field.id }}]"
              payload-name="image"
              height="120px"
            >
              <div class="nr-profile-form__upload-placeholder">
                <i class="sicon-camera"></i>
                <p>{{ trans('common.uploader.drag_and_drop') }}</p>
                <span>{{ trans('common.uploader.browse') }}</span>
              </div>
            </salla-file-upload>
            <input type="hidden" name="custom_fields[{{ field.id }}]" value="{{ field.value }}">
          {% else %}
            <input type="{{ field.type }}"
                   id="{{ field.id }}"
                   value="{{ field.value }}"
                   name="custom_fields[{{ field.id }}]"
                   class="nr-form-input" {{ field.required?'required':'' }}>
          {% endif %}
        </div>
      {% endfor %}

      {% hook 'customer:profile.form.fields.end' %}
    </div>

    {% hook 'customer:profile.form.submit.start' %}

    <salla-button type="submit" loader-position="end" class="nr-profile-form__submit">
      {{ trans('common.elements.save') }}
    </salla-button>

    {% hook 'customer:profile.form.submit.end' %}
  </form>
  {% hook 'customer:profile.form.end' %}

  <salla-verify></salla-verify>

  <salla-user-settings {{ user.is_notifiable?'is-notifiable':0 }} style="display:block;margin-top:var(--nr-space-xl)"></salla-user-settings>
{% endblock %}
