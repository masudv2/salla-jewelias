{#
| Variable                    | Type                   | Description |
|-----------------------------|------------------------|-------------|
| landing                     | object                 |             |
| landing.id                  | int                    |             |
| landing.title               | string                 |             |
| landing.content             | string                 |             |
| landing.products            | Products[] *Collection |             |
| landing.offer_ends_at       | ?date                  |             |
| landing.testimonials_type   | string                 |             |
| landing.show_quantity       | bool                   |             |
| landing.is_slider           | bool                   |             |
| landing.is_expired          | bool                   |             |
| landing.show_store_features | bool                   |             |
#}
{% extends "layouts.master" %}
{% block content %}
<script>
  window.showQuantity = {{ landing.show_quantity ? 'true' : 'false' }}
</script>

{% if not landing %}
  <div class="nr-landing nr-landing--notfound">
    <div class="nr-landing__header nr-container">
      <a href="{{ store.url }}" aria-label="{{ store.name }} logo">
        <img src="{{ store.logo }}" width="75" height="75" alt="logo" class="nr-landing__logo">
      </a>
      <h1 class="nr-landing__title">{{ trans('common.errors.404') }}</h1>
      <salla-button href="{{ link('/') }}" color="primary">{{ trans('common.elements.back_home') }}</salla-button>
    </div>
  </div>
{% elseif landing.is_expired %}
  <div class="nr-landing nr-landing--expired">
    <div class="nr-landing__header nr-container">
      <a href="{{ store.url }}" aria-label="{{ store.name }} logo">
        <img src="{{ store.logo }}" width="75" height="75" alt="logo" class="nr-landing__logo">
      </a>
      <h1 class="nr-landing__title">{{ trans('pages.offer.offer_finished') }}</h1>
      <p class="nr-landing__subtitle">{{ trans('pages.offer.offer_expired_message') }}</p>
      <salla-button href="{{ link('/') }}" color="primary">{{ trans('common.elements.back_home') }}</salla-button>
    </div>
  </div>
{% else %}
  <div class="nr-landing">
    <div class="nr-landing__header nr-container">
      <a href="{{ store.url }}" aria-label="{{ store.name }} logo">
        <img src="{{ store.logo }}" width="75" height="75" alt="logo" class="nr-landing__logo">
      </a>
      <h1 class="nr-landing__title">{{ landing.title }}</h1>
      <div class="nr-landing__subtitle">{{ landing.content|raw }}</div>
      {% if landing.offer_ends_at %}
        <div class="nr-landing__countdown">
          <h3>{{ trans('pages.offer.offer_remaining_time') }}</h3>
          <salla-count-down date="{{ landing.offer_ends_at }}" labeled size="lg"></salla-count-down>
        </div>
      {% endif %}
    </div>

    <section class="nr-container">
      {% if landing.is_slider %}
        <salla-products-slider source="landing-page" block-title="{{ trans('pages.offer.included_products') }}" display-all-url></salla-products-slider>
      {% else %}
        <div class="nr-section-header" style="margin-bottom:var(--nr-space-lg)">
          <h2 class="nr-section__title">{{ trans('pages.offer.included_products') }}</h2>
        </div>
        <salla-products-list source="landing-page"></salla-products-list>
      {% endif %}

      <div class="nr-landing__quick-buy">
        <salla-mini-checkout-widget
          products="[{{ landing.products|map((product) => product.id)|join(',') }}]"
          language="{{ user.language_code }}"
          label="{{ trans('pages.orders.finish_payment') }}"
          store-id="{{ store.id }}"
          api="{{ store.api }}"
        ></salla-mini-checkout-widget>
      </div>
    </section>

    {% if landing.show_store_features %}
      <section class="nr-container">
        {% component 'home.store-features' %}
      </section>
    {% endif %}

    {% if landing.testimonials_type %}
      <section class="nr-container" style="margin-top:var(--nr-space-xl)">
        {% component 'home.testimonials' with{type:landing.testimonials_type} %}
      </section>
    {% endif %}
  </div>
{% endif %}
{% endblock %}
