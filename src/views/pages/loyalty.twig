{#
| Variable                             | Type          | Description                                  |
|--------------------------------------|---------------|----------------------------------------------|
| page                                 | Page          |                                              |
| page.title                           | string        |                                              |
| page.slug                            | string        |                                              |
| loyalty                              | Loyalty       |                                              |
| loyalty.name                         | string        |                                              |
| loyalty.description                  | string        |                                              |
| loyalty.image                        | string        |                                              |
| loyalty.promotion_title              | string        |                                              |
| loyalty.promotion_description        | string        |                                              |
| loyalty.points                       | Point[]       |                                              |
| loyalty.points[].name                | string        |                                              |
| loyalty.points[].description         | string        |                                              |
| loyalty.points[].type                | string        | share, rating, order, profile                |
| loyalty.points[].url                 | ?string       |                                              |
| loyalty.points[].points              | int           |                                              |
| loyalty.points[].icon                | string        |                                              |
| loyalty.points[].color               | string        |                                              |
| loyalty.prizes[]                     | PrizesGroup[] |                                              |
| loyalty.prizes[].title               | string        |                                              |
| loyalty.prizes[].type                | string        | free_product, coupon_discount, free_shipping |
| loyalty.prizes[].items[]             | Prize[]       |                                              |
| loyalty.prizes[].items[].id          | int           |                                              |
| loyalty.prizes[].items[].name        | string        |                                              |
| loyalty.prizes[].items[].description | string        |                                              |
| loyalty.prizes[].items[].image       | string        |                                              |
| loyalty.prizes[].items[].url         | ?string       |                                              |
| loyalty.prizes[].items[].cost_points | int           |                                              |
| user.loyalty_points                  | ?int          |                                              |
| user.is_profile_completed            | bool          |                                              |
#}
{% extends "layouts.master" %}

{% block content %}
<div class="nr-loyalty-hero" style="background-image:url({{ loyalty.image }})">
  <div class="nr-loyalty-hero__overlay"></div>
</div>

<div class="nr-container nr-loyalty">
  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <div class="nr-loyalty__banner">
    <i class="sicon-star2 nr-loyalty__star"></i>
    <div class="nr-loyalty__banner-content">
      <h1 class="nr-loyalty__title">{{ loyalty.name }}</h1>
      <p class="nr-loyalty__desc">{{ loyalty.description }}</p>
      {% if user.loyalty_points %}
        <div class="nr-loyalty__points">
          {{ trans('pages.loyalty_program.you_have') }}
          <span class="count-number count-anime" data-count="{{ user.loyalty_points }}">0</span>
          {{ trans("pages.loyalty_program.point") }}
        </div>
      {% endif %}
    </div>
    <salla-loyalty customer-points="{{ user.loyalty_points }}">
      <salla-button onclick="document.querySelector('salla-loyalty').open();" slot="widget">
        {{ trans("pages.loyalty_program.exchange_points") }}
      </salla-button>
    </salla-loyalty>
  </div>

  <section class="nr-loyalty__ways">
    <div class="nr-section-header">
      <h2 class="nr-section__title">{{ trans("pages.loyalty_program.ways_to_get_points") }}</h2>
    </div>
    <div class="nr-loyalty__ways-list">
      {% for point in loyalty.points %}
        <div class="nr-loyalty__way-item">
          <div class="nr-loyalty__way-info">
            <span class="nr-loyalty__way-icon {{ point.icon ?: 'sicon-star' }}" style="color:{{ point.color }}">
              <span style="background-color:{{ point.color }}"></span>
            </span>
            <div>
              <h3 style="color:{{ point.color }}">{{ point.points }} {{ trans("pages.loyalty_program.point") }}</h3>
              <p>{{ point.description }}</p>
            </div>
          </div>

          {% if user.type == 'user' %}
            <div class="nr-loyalty__way-action">
              {% if point.type == 'share' %}
                <div class="nr-loyalty__share-link">
                  <salla-button onclick="app.copyToClipboard(event)" shape="link" data-content="{{ point.url }}"
                    title="{{ trans('pages.loyalty_program.copy_link') }}">
                    <i class="copy-icon sicon-swap-fill"></i>
                  </salla-button>
                  <span dir="ltr">{{ point.url }}</span>
                </div>
              {% elseif customer.is_profile_completed and point.type == 'profile' %}
                <span class="nr-loyalty__completed">
                  <i class="sicon-check-circle"></i> {{ trans('pages.loyalty_program.completed') }}
                </span>
              {% else %}
                <salla-button fill="outline" width="wide" href="{{ point.url }}">
                  {{ point.name }}
                </salla-button>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </section>

  {% for prize_group in loyalty.prizes %}
    <div style="margin-top:var(--nr-space-xl)">
      <salla-slider
        type="carousel"
        loop="{{ prize_group.items|length < 4 ? 'false' : 'true' }}"
        block-title="{{ prize_group.title }}"
        id="loyalty-slider-{{ prize_group.type }}">
        <div slot="items">
          {% for prize in prize_group.items %}
            <div class="slide--one-fourth">
              <div class="nr-loyalty__prize-card">
                {% if prize.url %}
                  <a href="{{ prize.url }}" class="nr-loyalty__prize-img">
                    <img src="{{ prize.image }}" loading="lazy" alt="{{ prize.name }}">
                  </a>
                {% else %}
                  <div class="nr-loyalty__prize-img">
                    <img src="{{ prize.image }}" loading="lazy" alt="{{ prize.name }}">
                  </div>
                {% endif %}
                <div class="nr-loyalty__prize-info">
                  <h3>{% if prize.url %}<a href="{{ prize.url }}">{{ prize.name }}</a>{% else %}{{ prize.name }}{% endif %}</h3>
                  <p>{{ prize.description }}</p>
                </div>
                {% if user.type == 'user' %}
                  <div class="nr-loyalty__prize-cost">
                    {{ prize.cost_points }} {{ trans("pages.loyalty_program.point") }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </salla-slider>
    </div>
  {% endfor %}
</div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'pages.js' | asset }}"></script>
{% endblock %}
