{#
| Variable       | Type    | Description                                        |
|----------------|---------|----------------------------------------------------|
| product        | Product | Full product object                                |
| product.id     | int     |                                                    |
| product.name   | string  |                                                    |
| product.images | array   | Images with .id, .url, .alt, .video_url, .type     |
| ...            |         | See Salla product docs for full list               |
#}
{% extends "layouts.master" %}
{% block content %}
<div class="nr-container nr-pdp">

  <nav class="nr-pdp__breadcrumb">
    <salla-breadcrumb></salla-breadcrumb>
  </nav>

  <div class="nr-pdp__layout" id="product-{{ product.id }}">

    {# === Gallery === #}
    <div class="nr-pdp__gallery">
      {% set has_many_images = product.images|length > 1 %}
      <salla-slider
        id="details-slider-{{ product.id }}"
        class="nr-pdp__slider"
        type="thumbs"
        loop="false"
        auto-height
        listen-to-thumbnails-option
        show-thumbs-controls="false">

        {% if product.promotion_title %}
          <div class="nr-pdp__promo-badge">{{ product.promotion_title }}</div>
        {% endif %}

        <button class="nr-pdp__wishlist"
                data-id="{{ product.id }}"
                onclick="salla.wishlist.toggle('{{ product.id }}')"
                aria-label="{{ trans('pages.products.add_to_wishlist') }}">
          <i class="sicon-heart"></i>
        </button>

        {% if product.calories %}
          <div class="nr-pdp__calories">
            <span class="nr-pdp__calories-num">{{ product.calories }}</span>
            <span class="nr-pdp__calories-label">{{ trans('pages.products.calories') }}</span>
          </div>
        {% endif %}

        <div slot="items">
          {% for image in product.images %}
            {% if image.three_d_image_url %}
              <model-viewer style="min-height:500px" class="swiper-slide model-entry"
                loading="eager" camera-controls touch-action="pan-y" auto-rotate
                poster="{{ image.url }}" src="{{ image.three_d_image_url }}"
                shadow-intensity="1" alt="{{ image.alt }}">
              </model-viewer>
            {% else %}
              <a data-fslightbox="product_{{ product.id }}"
                 data-img-id="{{ image.id }}"
                 data-slid-index="{{ loop.index - 1 }}"
                 {% if image.video_url %}data-video-src="{{ image.video_url }}"{% endif %}
                 data-caption="{{ image.alt }}"
                 data-infinite="false"
                 data-type="{{ image.video_url ? 'youtube' : 'image' }}"
                 href="{{ (image.video_url is iterable ? image.video_url|first : image.video_url)|default(image.url) }}"
                 aria-label="{{ product.name }}"
                 class="swiper-slide magnify-wrapper {{ image.video_url ? 'video-entry' : '' }}">
                <img id="{{ image.id }}"
                     src="{{ image.url }}"
                     loading="{{ loop.first ? 'eager' : 'lazy' }}"
                     {% if loop.first %}fetchpriority="high"{% endif %}
                     alt="{{ image.alt }}"
                     class="nr-pdp__main-img">
              </a>
            {% endif %}
          {% endfor %}
        </div>

        {% if has_many_images %}
          <div slot="thumbs">
            {% for image in product.images %}
              <div class="nr-pdp__thumb {{ image.video_url ? 'video-entry' : '' }} {{ image.three_d_image_url ? 'model-entry' : '' }}">
                <img src="{{ image.url }}"
                     loading="{{ loop.index < 5 ? 'eager' : 'lazy' }}"
                     alt="{{ image.alt }}">
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </salla-slider>
    </div>

    {# === Product Info === #}
    <div class="nr-pdp__info">

      {% hook 'product:single.description.start' %}

      {% if product.brand.name %}
        <a class="nr-pdp__brand" href="{{ product.brand.url }}" title="{{ product.brand.name }}">
          <img src="{{ product.brand.logo }}" alt="{{ product.brand.name }}">
        </a>
      {% endif %}

      <h1 class="nr-pdp__title">{{ product.name }}</h1>

      {% if product.subtitle %}
        <p class="nr-pdp__subtitle">{{ product.subtitle }}</p>
      {% endif %}

      {% if product.rating %}
        <div class="nr-pdp__rating">
          <salla-rating-stars value="{{ product.rating.stars }}" reviews="{{ product.rating.count }}"></salla-rating-stars>
        </div>
      {% endif %}

      {# Price #}
      <div class="nr-pdp__price">
        {% if product.is_on_sale %}
          <span class="nr-pdp__price-sale">{{ product.sale_price|money }}</span>
          <span class="nr-pdp__price-was">{{ product.regular_price|money }}</span>
          {% if product.discount_percentage %}
            <span class="nr-pdp__price-discount">-{{ product.discount_percentage }}</span>
          {% endif %}
        {% else %}
          {% if product.starting_price %}
            <span class="nr-pdp__price-starting">{{ trans('pages.products.starting_price') }}</span>
          {% endif %}
          <span class="nr-pdp__price-current">{{ product.starting_price ? product.starting_price|money : product.price|money }}</span>
        {% endif %}
      </div>

      {% if product.is_taxable %}
        <small class="nr-pdp__tax">{{ trans('pages.products.tax_included') }}</small>
      {% endif %}

      {# Description #}
      <div class="nr-pdp__desc">
        {% set product_desc = product.description|replace({"&nbsp;": "\n"}) %}
        {% if product.has_read_more %}
          <article class="nr-pdp__article nr-pdp__article--truncated" id="more-content">
            {{ product_desc|raw }}
          </article>
          <a id="btn-show-more" class="nr-pdp__read-more">{{ trans('pages.products.read_more') }}</a>
        {% else %}
          <article class="nr-pdp__article">{{ product_desc|raw }}</article>
        {% endif %}
      </div>

      {# Tags #}
      {% if product.tags|length and theme.settings.get('show_tags', true) %}
        <div class="nr-pdp__tags">
          {% for tag in product.tags %}
            <a href="{{ tag.url }}" class="nr-pdp__tag">{{ tag.name }}</a>
          {% endfor %}
        </div>
      {% endif %}

      {# Share + Wishlist #}
      <div class="nr-pdp__actions-row">
        <salla-social-share class="nr-pdp__share" aria-label="social share"></salla-social-share>
        <button class="nr-pdp__wishlist-btn"
                onclick="salla.wishlist.toggle('{{ product.id }}')"
                aria-label="{{ trans('pages.products.add_to_wishlist') }}">
          <i class="sicon-heart"></i>
        </button>
      </div>

      {# Sold / Remaining #}
      {% if product.sold_quantity or product.can_show_remained_quantity %}
        <div class="nr-pdp__stock-info">
          {% if product.sold_quantity %}
            <span class="nr-pdp__sold">
              <i class="sicon-fire"></i>
              {{ trans('pages.products.sold') }} {{ pluralize('pages.products.sold_times', product.sold_quantity)|raw }}
            </span>
          {% endif %}
          {% if product.can_show_remained_quantity %}
            <span class="nr-pdp__remaining">
              <i class="sicon-box-bankers"></i>
              {{ trans('pages.products.remained') }} {{ product.quantity }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if product.sku %}
        <div class="nr-pdp__sku">
          <i class="sicon-barcode"></i>
          <span>{{ trans('pages.products.sku') }}</span>
          <span class="nr-pdp__sku-value">{{ product.sku }}</span>
        </div>
      {% endif %}

      {% hook 'product:single.description' %}

      <salla-installment price="{{ product.price }}"></salla-installment>

      {% if product.has_metadata %}
        <salla-metadata></salla-metadata>
      {% endif %}

      {% if product.show_availability %}
        <div class="nr-pdp__availability">
          <span><i class="sicon-location"></i> {{ trans('pages.products.availability') }}</span>
          <a href="#!" onclick="salla.event.dispatch('scopes::open', {mode: 'availability', product_id: '{{ product.id }}' })">
            {{ trans('pages.products.select_branch') }}
            <i class="sicon-keyboard_arrow_left"></i>
          </a>
        </div>
      {% endif %}

      {% if product.digital_files_settings %}
        <digital-files-settings settings='{{ product.digital_files_settings|json_encode }}'></digital-files-settings>
      {% endif %}

      {# Product Form #}
      <form class="nr-pdp__form product-form" enctype="multipart/form-data" method="post"
            onsubmit="return salla.form.onSubmit('cart.addItem', event)">
        <input type="hidden" name="id" value="{{ product.id }}">

        {% hook 'product:single.form.start' %}
        {% include 'pages.partials.product.options' %}
        {% hook 'product:single.form.end' %}

        {# Price in form #}
        <div class="nr-pdp__form-price">
          <label class="nr-pdp__form-price-label">{{ trans('pages.products.price') }}</label>
          <div class="nr-pdp__price">
            <div class="{{ product.is_on_sale ? '' : 'hidden' }} price_is_on_sale">
              <span class="total-price nr-pdp__price-sale">{{ product.sale_price|money }}</span>
              <span class="before-price nr-pdp__price-was">{{ product.regular_price|money }}</span>
            </div>
            <div class="starting-or-normal-price {{ product.is_on_sale ? 'hidden' : '' }}">
              {% if product.starting_price %}
                <span class="starting-price-title nr-pdp__price-starting">{{ trans('pages.products.starting_price') }}</span>
              {% endif %}
              <span class="total-price nr-pdp__price-current">{{ product.starting_price ? product.starting_price|money : product.price|money }}</span>
            </div>
          </div>
          <div class="out-of-stock hidden nr-pdp__out-of-stock">{{ trans('pages.products.out_of_stock') }}</div>
        </div>

        {# Pre-order #}
        {% if product.has_preorder_campaign %}
          <div class="nr-pdp__preorder">
            <salla-count-down pre-order='{{ product.preorder|json_encode }}' boxed labeled></salla-count-down>
          </div>
        {% endif %}

        {# Quantity #}
        <div class="nr-pdp__cart-section sticky-product-bar">
          {% if product.is_hidden_quantity or product.type == 'booking' %}
            <input type="hidden" value="1" name="quantity" aria-label="Quantity">
          {% else %}
            <div class="nr-pdp__quantity sticky-product-bar__quantity">
              <label>{{ trans('pages.products.quantity') }}</label>
              <salla-quantity-input max="{{ product.max_quantity }}" value="1" name="quantity" aria-label="Quantity"></salla-quantity-input>
            </div>
          {% endif %}

          <salla-add-product-button
            {{ product.can_quick_buy ? 'quick-buy' : '' }}
            {{ theme.settings.get('sticky_add_to_cart') ? 'support-sticky-bar' : '' }}
            {{ product.is_require_shipping ? 'required-shipping' : '' }}
            {{ product.has_preorder_campaign ? 'has-pre-order' : '' }}
            amount="{{ product.base_currency_price }}"
            class="nr-pdp__add-btn sticky-product-bar__btn"
            product-status="{{ product.status }}"
            product-type="{{ product.type }}"
            product-id="{{ product.id }}"
            loader-position="end"
            type="submit"
            width="wide"
            {% if product.notify_availability %}
              {{ product.notify_availability.subscribed ? 'is-subscribed' : '' }}
              channels="{{ product.notify_availability.channels|join(',') }}"
              subscribed-options="{{ product.notify_availability.subscribed_options|json_encode }}"
              {{ product.notify_availability.options ? 'notify-options-availability' : '' }}
            {% endif %}>
            {{ product.add_to_cart_label }}
          </salla-add-product-button>
        </div>

        {% if product.is_giftable %}
          <salla-gifting widget-subtitle="{{ gifting_intro }}" product-id="{{ product.id }}" {{ product.is_require_shipping ? 'physical-products' : '' }}></salla-gifting>
        {% endif %}
      </form>

      {% hook 'product:single.description.end' %}
      <salla-quick-order class="nr-pdp__quick-order"></salla-quick-order>
    </div>
  </div>

  <salla-offer></salla-offer>
</div>

{# Reviews #}
{% if store.settings.rating.show_on_product %}
  <div class="nr-container">
    <salla-comments item-id="{{ product.id }}" type="product"></salla-comments>
  </div>
{% endif %}

{# Related Products #}
<div class="nr-container nr-section">
  <salla-products-slider source="related" source-value="{{ product.id }}" block-title="{{ trans('pages.products.similar_products') }}" display-all-url></salla-products-slider>
</div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'product.js'|asset }}"></script>
  {% if product.has_3d_image %}
    <script type="module" defer src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  {% endif %}
  {% if product.digital_files_settings %}
    <script type="module" defer src="{{ 'digital-files.js'|asset }}"></script>
  {% endif %}
{% endblock %}
