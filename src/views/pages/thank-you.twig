{#
| Variable            | Type   | Description                            |
|---------------------|--------|----------------------------------------|
| page                | object |                                        |
| page.title          | string |                                        |
| page.slug           | string |                                        |
| order               | Order  | @see pages/customer/orders/single.twig |
| thank_you           | string |                                        |
| share_message       | string |                                        |
| short_share_message | string |                                        |
#}
{% extends "layouts.master" %}

{% block content %}
{% hook 'thank-you:start' %}
<div class="nr-container nr-thankyou">
  <nav class="nr-pdp__breadcrumb">
    <ol class="nr-thankyou__crumbs">
      <li><a href="{{ link('/') }}">{{ trans('common.titles.home') }}</a></li>
      <li><i class="sicon-keyboard_arrow_left"></i></li>
      <li><span>{{ thank_you_title }}</span></li>
    </ol>
  </nav>

  <div class="nr-thankyou__card">
    <div class="nr-thankyou__hero">
      <div class="nr-thankyou__icon-wrap {{ theme.is_rtl ? 'flip-x' : '' }}">
        <img src="{{ 'images/delivery-bro.svg' | asset }}" alt="{{ thank_you_title }}" class="nr-thankyou__img thanks-item opacity-0">
      </div>
      <h1 class="nr-thankyou__title thanks-item opacity-0">{{ thank_you_title }}</h1>
      <p class="nr-thankyou__ref thanks-item opacity-0">
        {{ trans('pages.thank_you.order_id') }}
        <salla-button onclick="app.copyToClipboard(event)" color="dark" shape="link" data-content="{{ order.reference_id }}">
          <span>#{{ order.reference_id }}</span>
          <i class="copy-icon sicon-swap-stroke pointer-events-none"></i>
        </salla-button>
      </p>
      <salla-button onclick="salla.order.show({order_id:'{{ order.id }}', url:'{{ order.url }}'})">
        <i class="sicon-newspaper"></i>
        {{ trans('pages.thank_you.order_details') }}
      </salla-button>
    </div>

    {% if order.instructions %}
      <article class="nr-thankyou__instructions content-entry">
        {{ order.instructions|raw }}
      </article>
    {% endif %}

    {% for message in messages %}
      <div class="nr-thankyou__message">
        <span>{{ message }}</span>
      </div>
    {% endfor %}

    {% hook 'thank-you:items.start' %}
    {% hook 'thank-you:items.end' %}
  </div>

  <div class="nr-thankyou__actions">
    {% if order.email_sent %}
      <div class="nr-thankyou__action-card">
        <i class="sicon-newspaper-alt nr-thankyou__action-icon"></i>
        <p>{{ trans('pages.thank_you.email_sent') }}</p>
        <b>{{ order.customer.email }}</b>
      </div>
    {% else %}
      <div class="nr-thankyou__action-card" id="invoice-form">
        <i class="sicon-newspaper-alt nr-thankyou__action-icon"></i>
        <p>{{ trans('pages.thank_you.resend_email') }}</p>
        <form onsubmit="return salla.form.onSubmit('order.sendInvoice', event)" class="nr-thankyou__email-form">
          <input type="email" class="nr-form-input" placeholder="your@email.com" required name="email">
          <salla-button type="submit" loader-position="center">
            {{ trans('blocks.comments.submit') }}
          </salla-button>
        </form>
      </div>
    {% endif %}

    <div class="nr-thankyou__action-card">
      <i class="sicon-mail-letter nr-thankyou__action-icon"></i>
      <p>{{ trans('common.titles.support') }}</p>
      <div class="nr-thankyou__contacts">
        {% if store.contacts.mobile %}
          <a href="tel:{{ store.contacts.mobile }}"><i class="sicon-phone"></i> {{ store.contacts.mobile }}</a>
        {% endif %}
        {% if store.contacts.whatsapp %}
          <a href="https://wa.me/{{ store.contacts.whatsapp|replace({' ': '', '+': '', '-': ''}) }}" target="_blank" rel="noopener">
            <i class="sicon-whatsapp"></i> {{ store.contacts.whatsapp }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
  {% hook 'thank-you:end' %}
</div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'checkout.js' | asset }}"></script>
{% endblock %}
